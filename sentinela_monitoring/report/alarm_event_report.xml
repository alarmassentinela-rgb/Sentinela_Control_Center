<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_master_incident" model="ir.actions.report">
        <field name="name">Informe Maestro de Incidente</field>
        <field name="model">sentinela.alarm.event</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sentinela_monitoring.report_master_incident_template</field>
        <field name="report_file">sentinela_monitoring.report_master_incident_template</field>
        <field name="print_report_name">'Informe_Incidente_%s' % (object.name)</field>
        <field name="binding_model_id" ref="model_sentinela_alarm_event"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_master_incident_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica', sans-serif; color: #333;">
                        <!-- Encabezado -->
                        <div class="row mb-4" style="border-bottom: 3px solid #1a237e; padding-bottom: 10px;">
                            <div class="col-6">
                                <h3 style="color: #1a237e; font-weight: bold; margin-bottom: 0;">INFORME MAESTRO DE INCIDENTE</h3>
                                <div style="margin-top: 5px;">
                                    <span class="badge bg-danger" style="font-size: 14px; padding: 5px 10px;">
                                        FOLIO: <t t-esc="o.name"/>
                                    </span>
                                </div>
                            </div>
                            <div class="col-6 text-end">
                                <div style="font-size: 12px;"><b>Prioridad:</b> <span t-field="o.priority_display"/></div>
                                <div style="font-size: 12px;"><b>Estado:</b> <span t-field="o.status"/></div>
                            </div>
                        </div>

                        <!-- Datos Abonado -->
                        <div class="row mb-4">
                            <div class="col-7">
                                <h5 style="background: #f0f2f5; padding: 5px 10px; border-radius: 5px; color: #1a237e; font-size: 14px; font-weight: bold;">DATOS DEL ABONADO</h5>
                                <div style="padding-left: 10px; margin-top: 10px;">
                                    <div style="font-size: 16px; font-weight: bold;"><span t-field="o.partner_id.name"/></div>
                                    <div style="font-size: 12px; color: #666;"><span t-field="o.location"/></div>
                                    <div style="font-size: 12px;"><b>Cuenta Central:</b> <span t-field="o.account_number"/></div>
                                </div>
                            </div>
                            <div class="col-5">
                                <h5 style="background: #f0f2f5; padding: 5px 10px; border-radius: 5px; color: #1a237e; font-size: 14px; font-weight: bold;">RESUMEN TEMPORAL</h5>
                                <div style="padding-left: 10px; margin-top: 10px; font-size: 12px;">
                                    <div><b>Inicio:</b> <span t-field="o.start_date" t-options='{"widget": "datetime"}'/></div>
                                    <div><b>Cierre:</b> <span t-field="o.end_date" t-options='{"widget": "datetime"}'/></div>
                                    <div><b>Operador:</b> <span t-field="o.assigned_operator_id.name"/></div>
                                </div>
                            </div>
                        </div>

                        <!-- Bloque 1: Señales -->
                        <div class="mb-4">
                            <h5 style="border-left: 4px solid #1a237e; padding-left: 10px; color: #1a237e; font-weight: bold; font-size: 15px;">1. CRONOLOGÍA DE SEÑALES</h5>
                            <table class="table table-sm mt-2" style="font-size: 11px;">
                                <thead style="background: #1a237e; color: white;">
                                    <tr>
                                        <th>Hora</th>
                                        <th>Evento / Zona</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.alarm_signal_ids" t-as="s">
                                        <tr>
                                            <td><span t-field="s.received_date" t-options='{"widget": "datetime", "format": "HH:mm:ss"}'/></td>
                                            <td><span t-field="s.description"/></td>
                                            <td><span t-field="s.status"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Bloque 2: Patrulla -->
                        <t t-set="patrol" t-value="o.fsm_order_ids.filtered(lambda x: x.service_type == 'patrol')[:1]"/>
                        <div class="mb-4" t-if="patrol">
                            <h5 style="border-left: 4px solid #d32f2f; padding-left: 10px; color: #d32f2f; font-weight: bold; font-size: 15px;">2. REPORTE DE INSPECCIÓN (PATRULLA)</h5>
                            <div class="row mt-2" style="background: #fff5f5; border: 1px solid #ffcdd2; border-radius: 8px; padding: 10px; margin: 0;">
                                <div class="col-4">
                                    <div class="small text-muted">OFICIAL</div>
                                    <div class="fw-bold"><span t-field="patrol.technician_id.name"/></div>
                                </div>
                                <div class="col-4 text-center">
                                    <div class="small text-muted">DICTAMEN</div>
                                    <div class="fw-bold text-danger"><span t-field="o.patrol_dictum_display"/></div>
                                </div>
                                <div class="col-4 text-end">
                                    <div class="small text-muted">ARRIBO</div>
                                    <div class="fw-bold"><span t-field="patrol.arrival_date" t-options='{"widget": "datetime", "format": "HH:mm:ss"}'/></div>
                                </div>
                            </div>
                        </div>

                        <!-- Bloque 3: Evidencias -->
                        <div class="mb-4" t-if="patrol and patrol.evidence_ids">
                            <h5 style="border-left: 4px solid #1a237e; padding-left: 10px; color: #1a237e; font-weight: bold; font-size: 15px;">3. EVIDENCIAS FOTOGRÁFICAS</h5>
                            <div class="row mt-2">
                                <t t-foreach="patrol.evidence_ids[:4]" t-as="ev">
                                    <div class="col-3 text-center mb-2">
                                        <div t-if="ev.image" t-field="ev.image" t-options='{"widget": "image", "class": "img-thumbnail", "style": "height: 100px; width: 100%; object-fit: cover;"}'/>
                                        <div class="extra-small text-muted mt-1"><t t-esc="ev.name"/></div>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <!-- Bloque 4: Cierre -->
                        <div style="background: #1a237e; color: white; border-radius: 10px; padding: 15px;" class="mt-4">
                            <h6 style="font-weight: bold; border-bottom: 1px solid rgba(255,255,255,0.3); padding-bottom: 5px;">4. CONCLUSIÓN FINAL DE LA CENTRAL</h6>
                            <p style="font-size: 13px; font-style: italic; margin-top: 10px;">
                                <span t-field="o.operator_final_remarks"/>
                                <t t-if="not o.operator_final_remarks">Evento gestionado bajo protocolos estándar de seguridad.</t>
                            </p>
                            <div class="row mt-4" style="font-size: 11px; opacity: 0.8;">
                                <div class="col-12 text-end">
                                    <b>Sello de Validación Sentinela</b><br/>
                                    ID: <span t-field="o.id"/> | <span t-field="o.start_date" t-options='{"widget": "date"}'/>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
