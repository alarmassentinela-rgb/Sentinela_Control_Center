<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sentinela_alarm_handle_wizard_form" model="ir.ui.view">
        <field name="name">sentinela.alarm.handle.wizard.form</field>
        <field name="model">sentinela.alarm.handle.wizard</field>
        <field name="arch" type="xml">
            <form string="Centro de Control de Alarma">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="verify,contact,dispatch,close"/>
                </header>
                <sheet>
                    <!-- ===== CABECERA ===== -->
                    <div class="oe_title mb-2">
                        <h1 class="d-flex align-items-center gap-2">
                            <span class="badge bg-dark text-white"><field name="account_number"/></span>
                            <field name="partner_id" readonly="1"/>
                            <field name="priority_id" widget="badge" readonly="1"/>
                        </h1>
                        <h3 class="text-danger fw-bold"><field name="full_description" readonly="1"/></h3>
                    </div>

                    <!-- Badges de estado (color por valor con invisible, sin decoration) -->
                    <field name="subscription_state" invisible="1"/>
                    <field name="sla_status" invisible="1"/>
                    <field name="google_maps_link" invisible="1"/>
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                        <span class="badge bg-success" invisible="subscription_state != 'active'">✔ Suscripción activa</span>
                        <span class="badge bg-warning text-dark" invisible="subscription_state != 'suspended'">⚠ Suscripción SUSPENDIDA</span>
                        <span class="badge bg-danger" invisible="subscription_state != 'cut'">⛔ Suscripción CANCELADA</span>
                        <span class="badge bg-secondary" invisible="subscription_state != 'none'">Sin suscripción</span>
                        <span class="badge bg-success" invisible="sla_status not in ('ok','met')">SLA OK</span>
                        <span class="badge bg-warning text-dark" invisible="sla_status != 'warning'">SLA por vencer</span>
                        <span class="badge bg-danger" invisible="sla_status not in ('overdue','breached')">SLA VENCIDO</span>
                        <span class="text-muted small" invisible="not sla_deadline">Vence: <field name="sla_deadline" readonly="1" class="oe_inline"/></span>
                    </div>

                    <!-- Alertas -->
                    <field name="possible_false_alarm" invisible="1"/>
                    <field name="false_alarm_hint" invisible="1"/>
                    <field name="sibling_event_count" invisible="1"/>
                    <div class="alert alert-danger fw-bold" role="alert" invisible="not possible_false_alarm">
                        ⚠️ <field name="false_alarm_hint" class="oe_inline" readonly="1"/>
                    </div>
                    <div class="alert alert-info d-flex align-items-center justify-content-between" role="alert" invisible="sibling_event_count == 0">
                        <span>🔁 Este cliente tiene <field name="sibling_event_count" class="oe_inline"/> evento(s) más abiertos.</span>
                        <button name="action_bulk_close" type="object" string="Cerrar este + relacionados en bloque" class="btn-primary btn-sm" icon="fa-check-double"/>
                    </div>

                    <!-- Palabra clave -->
                    <div class="alert alert-warning text-center mb-2" role="alert" invisible="not verification_password">
                        🔑 <strong>PALABRA CLAVE:</strong>
                        <span class="fs-5 fw-bold ms-2"><field name="verification_password" readonly="1" class="oe_inline"/></span>
                    </div>

                    <!-- ===== DATOS DEL EVENTO ===== -->
                    <group string="📍 Datos del Evento">
                        <group>
                            <field name="alarm_code_id" readonly="1" string="Código de alarma"/>
                            <field name="start_date" readonly="1" string="Hora del evento"/>
                            <field name="zone" readonly="1" string="Zona"/>
                            <field name="full_description" readonly="1" string="Descripción"/>
                            <field name="priority_id" readonly="1" string="Prioridad"/>
                        </group>
                        <group>
                            <field name="event_address" readonly="1"/>
                            <field name="latitude" readonly="1" string="Latitud"/>
                            <field name="longitude" readonly="1" string="Longitud"/>
                            <button name="action_open_maps" type="object" string="📍 Ver en Google Maps"
                                    class="btn-secondary" invisible="not google_maps_link"/>
                        </group>
                    </group>

                    <!-- ===== CONTACTOS (siempre, con click-to-call) ===== -->
                    <group string="📞 Contactos del sitio (pulsa el botón verde para llamar por la central)">
                        <field name="contact_attempt_ids" nolabel="1">
                            <list editable="bottom" create="false" delete="false">
                                <field name="contact_id" column_invisible="1"/>
                                <field name="sequence" widget="handle"/>
                                <field name="contact_name" readonly="1"/>
                                <field name="contact_phone" widget="phone" readonly="1"/>
                                <button name="action_call" type="object" icon="fa-phone"
                                        title="Marcar por la central UCM" class="btn-success"/>
                                <field name="relation" readonly="1"/>
                                <field name="status"/>
                                <field name="attempt_notes"/>
                            </list>
                        </field>
                    </group>

                    <!-- ===== DESPACHO DE PATRULLERO (siempre visible) ===== -->
                    <field name="patrol_inclusion_status" invisible="1"/>
                    <field name="extra_service_authorized" invisible="1"/>
                    <group string="🚓 Despacho de patrullero">
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-2" colspan="2">
                            <span class="badge bg-success" invisible="patrol_inclusion_status != 'included'">Patrullaje INCLUIDO en el plan</span>
                            <span class="badge bg-warning text-dark" invisible="patrol_inclusion_status != 'not_included'">Patrullaje NO incluido — requiere autorizar cobro</span>
                            <span class="badge bg-danger" invisible="patrol_inclusion_status != 'no_subscription'">Sin suscripción — no facturable</span>
                            <span class="badge bg-info" invisible="not extra_service_authorized">Cobro autorizado ✔</span>
                            <span class="text-muted" invisible="patrol_inclusion_status == 'included'">Costo extra del servicio: $<field name="patrol_extra_price" class="oe_inline" readonly="1"/></span>
                        </div>
                        <field name="technician_id"
                            domain="[('share', '=', False)]"
                            options="{'no_create': True}"
                            placeholder="Selecciona el patrullero a enviar"/>
                        <field name="dispatch_notes" placeholder="Notas del despacho (placa, etc.)"/>
                    </group>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <button name="action_request_patrol_from_wizard" string="Solicitar autorización (Telegram)"
                                type="object" class="btn-warning"
                                invisible="patrol_inclusion_status != 'not_included' or extra_service_authorized"/>
                        <button name="action_authorize_patrol_from_wizard" string="Marcar autorizado"
                                type="object" class="btn-info"
                                invisible="patrol_inclusion_status != 'not_included' or extra_service_authorized"/>
                        <button name="action_dispatch_patrol" string="🚓 ENVIAR PATRULLERO"
                                type="object" class="btn-danger"/>
                        <button name="action_create_technical_ticket" string="Crear orden técnica (FSM)"
                                type="object" class="btn-secondary"/>
                    </div>

                    <!-- ===== CIERRE (siempre visible) ===== -->
                    <group string="✅ Cierre del evento">
                        <field name="close_reason"/>
                        <field name="final_notes" placeholder="Notas finales que verá el cliente / quedará en el historial."/>
                    </group>

                    <!-- Emergencias + Historial + Bitácora en pestañas -->
                    <notebook>
                        <page string="🕓 Historial del panel (24h)" name="historial">
                            <p class="text-muted">Todas las señales del panel en las últimas 24 h (incluye aperturas/cierres que no generan evento).</p>
                            <field name="account_signal_history_ids" readonly="1" nolabel="1">
                                <list limit="50">
                                    <field name="received_date" string="Hora"/>
                                    <field name="alarm_code" string="Código"/>
                                    <field name="zone" string="Zona"/>
                                    <field name="description" string="Descripción"/>
                                </list>
                            </field>
                        </page>
                        <page string="📝 Bitácora del operador" name="bitacora">
                            <field name="notes" nolabel="1" placeholder="Anota cualquier dato adicional aquí. Se guarda al cerrar."/>
                        </page>
                        <page string="☎ Emergencias" name="emergencias">
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge bg-danger p-2 fs-6">Emergencias: 911</span>
                                <span class="badge bg-success p-2 fs-6">Cruz Roja: 065</span>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_finalize" string="✅ Resolver y cerrar"
                            type="object" class="btn-success"/>
                    <button name="action_shortcut_false_alarm" string="Atajo: Falsa alarma"
                            type="object" class="btn-outline-secondary"/>
                    <button name="action_shortcut_customer_ok" string="Atajo: Cliente OK"
                            type="object" class="btn-outline-secondary"/>
                    <button name="action_pause_event" string="Pausar"
                            type="object" class="btn-secondary"/>
                    <button string="Cancelar" class="btn-link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sentinela_alarm_handle_wizard" model="ir.actions.act_window">
        <field name="name">Atender Alarma</field>
        <field name="res_model">sentinela.alarm.handle.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
