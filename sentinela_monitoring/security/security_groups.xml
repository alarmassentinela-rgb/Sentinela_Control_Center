<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- CATEGORIA DE SEGURIDAD SENTICAR -->
        <record id="module_category_senticar" model="ir.module.category">
            <field name="name">SentiCar (Rastreo GPS)</field>
            <field name="description">Gestión de flota y rastreo multi-cliente</field>
            <field name="sequence">10</field>
        </record>

        <!-- GRUPOS DE USUARIO -->
        <record id="group_senticar_customer" model="res.groups">
            <field name="name">SentiCar: Cliente</field>
            <field name="category_id" ref="module_category_senticar"/>
        </record>

        <record id="group_senticar_manager" model="res.groups">
            <field name="name">SentiCar: Administrador (Sentinela)</field>
            <field name="category_id" ref="module_category_senticar"/>
            <field name="implied_ids" eval="[(4, ref('group_senticar_customer'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- REGLAS DE REGISTRO (EL MURO) -->
        
        <!-- El Cliente solo ve sus propios dispositivos -->
        <record id="rule_senticar_device_customer" model="ir.rule">
            <field name="name">SentiCar: Ver mis propios vehículos</field>
            <field name="model_id" ref="sentinela_monitoring.model_sentinela_monitoring_device"/>
            <field name="domain_force">[('partner_id', 'child_of', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_senticar_customer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- El Administrador (Sentinela) ve TODO -->
        <record id="rule_senticar_device_manager" model="ir.rule">
            <field name="name">SentiCar: Administrador ve todo el Radar</field>
            <field name="model_id" ref="sentinela_monitoring.model_sentinela_monitoring_device"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_senticar_manager'))]"/>
        </record>

    </data>
</odoo>
