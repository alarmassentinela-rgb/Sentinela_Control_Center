<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="sentinela_monitoring.MonitoringDashboard" owl="1">
        <div class="o_monitoring_dashboard h-100 d-flex flex-column bg-white">
            <!-- HEADER -->
            <div class="o_monitoring_header p-3 bg-white border-bottom d-flex justify-content-between align-items-center shadow-sm">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-primary text-white rounded p-2"><i class="fa fa-shield fa-lg"></i></div>
                    <div>
                        <h4 class="m-0 fw-bold">SENTINELA CENTRO DE COMANDO</h4>
                        <small class="text-muted">Operación en Tiempo Real</small>
                    </div>
                    <button class="btn btn-sm btn-light border ms-3" t-on-click="loadData"><i class="fa fa-refresh"></i> RECARGAR</button>
                    <button t-att-class="'btn btn-sm border ms-2 ' + (state.audioMuted ? 'btn-warning' : 'btn-light')"
                            t-on-click="toggleAudioMute"
                            t-att-title="state.audioMuted ? 'Audio silenciado 5min — click para reactivar' : 'Click para silenciar audio 5min'">
                        <i t-att-class="'fa ' + (state.audioMuted ? 'fa-volume-off' : 'fa-volume-up')"></i>
                        <t t-esc="state.audioMuted ? ' SILENCIADO' : ' AUDIO'"/>
                    </button>
                </div>
                <div class="text-end">
                    <div t-if="state.receiverStatus === 'online'" class="text-success fw-bold"><i class="fa fa-circle me-1 fa-beat"></i>RECEPTOR ONLINE</div>
                    <div t-else="" class="text-danger fw-bold"><i class="fa fa-exclamation-triangle me-1"></i>RECEPTOR OFFLINE</div>
                    <small class="text-muted">Latido: <t t-esc="state.lastHeartbeat"/></small>
                </div>
            </div>
            
            <!-- TABS PRINCIPALES -->
            <ul class="nav nav-tabs px-3 pt-2 bg-light border-bottom">
                <li class="nav-item">
                    <a t-att-class="'nav-link ' + (state.currentTab === 'alarms' ? 'active fw-bold' : '')" href="#" t-on-click.prevent="() => this.setTab('alarms')">
                        ALARMAS (<t t-esc="state.alarmCount"/>)
                    </a>
                </li>
                <li class="nav-item">
                    <a t-att-class="'nav-link ' + (state.currentTab === 'pending' ? 'active fw-bold' : '')" href="#" t-on-click.prevent="() => this.setTab('pending')">
                        PENDIENTES (<t t-esc="state.pendingCount"/>)
                    </a>
                </li>
                <li class="nav-item">
                    <a t-att-class="'nav-link ' + (state.currentTab === 'traffic' ? 'active fw-bold' : '')" href="#" t-on-click.prevent="() => this.setTab('traffic')">
                        TRÁFICO
                    </a>
                </li>
            </ul>

            <!-- SUB-FILTROS DE TRÁFICO (Solo visibles en pestaña TRÁFICO) -->
            <div t-if="state.currentTab === 'traffic'" class="bg-light border-bottom px-3 py-2 d-flex gap-2 shadow-sm">
                <button t-att-class="'btn btn-sm ' + (state.trafficFilter === 'live' ? 'btn-primary' : 'btn-outline-secondary')" t-on-click="() => this.setTrafficFilter('live')">
                    <i class="fa fa-bolt me-1"></i> EN VIVO
                </button>
                <button t-att-class="'btn btn-sm ' + (state.trafficFilter === 'active' ? 'btn-danger' : 'btn-outline-secondary')" t-on-click="() => this.setTrafficFilter('active')">
                    <i class="fa fa-warning me-1"></i> ACTIVOS
                </button>
                <button t-att-class="'btn btn-sm ' + (state.trafficFilter === 'commented' ? 'btn-info' : 'btn-outline-secondary')" t-on-click="() => this.setTrafficFilter('commented')">
                    <i class="fa fa-comments me-1"></i> CON COMENTARIO
                </button>
            </div>

            <div class="flex-grow-1 overflow-auto p-0">
                
                <!-- TABLA: ALARMAS ACTIVAS -->
                <t t-if="state.currentTab === 'alarms'">
                    <table class="table table-hover m-0">
                        <thead class="bg-light sticky-top">
                            <tr>
                                <th class="ps-3">ID</th>
                                <th>CLIENTE</th>
                                <th>CUENTA</th>
                                <th>CÓDIGO</th>
                                <th>ZONA</th>
                                <th class="text-end pe-3">ACCIÓN</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.events" t-as="event" t-key="event.id">
                                <tr class="align-middle" t-on-dblclick="() => this.handleAlarm(event.id)">
                                    <td class="ps-3 fw-bold"><t t-esc="event.id"/></td>
                                    <td class="fw-bold"><t t-esc="event.partner_name"/></td>
                                    <td><span class="badge bg-dark text-white"><t t-esc="event.account"/></span></td>
                                    <td><b><t t-esc="event.code_display"/></b></td>
                                    <td><span class="badge bg-secondary"><t t-esc="event.zone"/></span></td>
                                    <td class="text-end pe-3">
                                        <button t-if="!event.is_blocked" class="btn btn-sm btn-outline-primary" t-on-click="() => this.handleAlarm(event.id)">ATENDER</button>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

                <!-- TABLA: EVENTOS PENDIENTES -->
                <t t-if="state.currentTab === 'pending'">
                    <table class="table table-hover m-0">
                        <thead class="bg-warning text-dark sticky-top">
                            <tr>
                                <th class="ps-3">ID</th>
                                <th>CLIENTE</th>
                                <th>CUENTA</th>
                                <th>ESTADO</th>
                                <th>INICIO</th>
                                <th class="text-end pe-3">ACCIÓN</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.pendingEvents" t-as="p" t-key="p.id">
                                <tr class="align-middle" t-on-dblclick="() => this.handleAlarm(p.id)">
                                    <td class="ps-3 fw-bold"><t t-esc="p.id"/></td>
                                    <td class="fw-bold"><t t-esc="p.partner_name"/></td>
                                    <td><t t-esc="p.account"/></td>
                                    <td><span class="badge bg-primary text-uppercase"><t t-esc="p.status"/></span></td>
                                    <td><t t-esc="p.start_date"/></td>
                                    <td class="text-end pe-3">
                                        <button class="btn btn-sm btn-primary" t-on-click="() => this.handleAlarm(p.id)">RETOMAR</button>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

                <!-- TABLA: TRÁFICO -->
                <!-- TABLA: COMENTADAS (eventos cerrados con comentario del operador) -->
                <t t-if="state.currentTab === 'traffic' and state.trafficFilter === 'commented'">
                    <table class="table table-sm table-hover m-0">
                        <thead class="bg-info text-dark sticky-top">
                            <tr>
                                <th class="ps-3">ID</th>
                                <th>PRIORIDAD</th>
                                <th>CLIENTE</th>
                                <th>CUENTA</th>
                                <th>CÓDIGO</th>
                                <th>CERRADO</th>
                                <th>MOTIVO</th>
                                <th>COMENTARIO DEL OPERADOR</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.commented" t-as="c" t-key="c.id">
                                <tr class="align-middle">
                                    <td class="ps-3"><t t-esc="c.id"/></td>
                                    <td>
                                        <span class="badge" t-att-style="'background-color:' + c.priority_color + ';color:' + c.priority_text_color + ';'">
                                            <t t-esc="c.priority_name"/>
                                        </span>
                                    </td>
                                    <td class="fw-bold"><t t-esc="c.client_name"/></td>
                                    <td><span class="badge bg-light text-dark border"><t t-esc="c.account"/></span></td>
                                    <td><b><t t-esc="c.code_display"/></b></td>
                                    <td><t t-esc="c.close_date"/></td>
                                    <td><span class="badge bg-secondary"><t t-esc="c.close_reason_label"/></span></td>
                                    <td style="white-space: pre-wrap; max-width: 420px;"><t t-esc="c.comment"/></td>
                                </tr>
                            </t>
                            <tr t-if="!state.commented.length">
                                <td colspan="8" class="text-center text-muted py-3">Sin eventos cerrados con comentarios.</td>
                            </tr>
                        </tbody>
                    </table>
                </t>

                <t t-if="state.currentTab === 'traffic' and state.trafficFilter !== 'commented'">
                    <table class="table table-sm table-hover m-0">
                        <thead class="bg-dark text-white sticky-top">
                            <tr>
                                <th class="ps-3">ID</th>
                                <th>PRIORIDAD</th>
                                <th>CLIENTE</th>
                                <th>FECHA</th>
                                <th>CUENTA</th>
                                <th>CÓDIGO</th>
                                <th>ZONA</th>
                                <th>DESCRIPCIÓN</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.signals" t-as="s" t-key="s.id">
                                <tr t-att-class="(s.is_blocked ? 'opacity-50 grayscale ' : '') + (s.processable ? 'cursor-pointer' : '')"
                                    t-att-title="s.processable ? 'Doble clic para atender el evento' : ''"
                                    t-att-style="'font-family: monospace;' + (s.processable ? ' cursor: pointer;' : '')"
                                    t-on-dblclick="() => s.processable ? this.handleAlarm(s.event_id) : null">
                                    <td class="ps-3"><t t-esc="s.id"/></td>
                                    <td>
                                        <span class="badge" t-att-style="'background-color:' + s.priority_color + ';color:' + s.priority_text_color + ';'">
                                            <t t-esc="s.priority_name"/>
                                        </span>
                                    </td>
                                    <td class="fw-bold"><t t-esc="s.client_name"/></td>
                                    <td><t t-esc="s.received_date"/></td>
                                    <td><span class="badge bg-light text-dark border"><t t-esc="s.account"/></span></td>
                                    <td><b><t t-esc="s.alarm_code"/></b></td>
                                    <td><t t-esc="s.zone"/></td>
                                    <td><b><t t-esc="s.zone_description"/></b></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
            </div>
        </div>
    </t>
</templates>
