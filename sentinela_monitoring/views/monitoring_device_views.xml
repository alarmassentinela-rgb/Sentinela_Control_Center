<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM VIEW -->
    <record id="view_monitoring_device_form" model="ir.ui.view">
        <field name="name">sentinela.monitoring.device.form</field>
        <field name="model">sentinela.monitoring.device</field>
        <field name="arch" type="xml">
            <form string="Dispositivo de Monitoreo">
                <header>
                    <button name="action_activate_device" string="Activar" type="object" class="btn-success" invisible="status == 'active'"/>
                    <button name="action_deactivate_device" string="Desactivar" type="object" class="btn-default" invisible="status == 'inactive'"/>
                    <button name="action_set_maintenance" string="Mantenimiento" type="object" class="btn-warning" invisible="status == 'maintenance'"/>
                    <field name="status" widget="statusbar" statusbar_visible="active,inactive,maintenance,faulty,offline"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Información del Dispositivo">
                            <field name="device_id" readonly="1"/>
                            <field name="account_number" groups="base.group_system"/>
                            <field name="account_number" groups="!base.group_system" readonly="1"/>
                            <field name="protocol" groups="base.group_system"/>
                            <field name="protocol" groups="!base.group_system" readonly="1"/>
                            <field name="device_type" groups="base.group_system"/>
                            <field name="device_type" groups="!base.group_system" readonly="1"/>
                            <field name="installation_date"/>
                            <field name="warranty_expiration"/>
                        </group>
                        <group string="Cliente">
                            <field name="partner_id"/>
                            <field name="allowed_subscription_ids" invisible="1"/>
                            <field name="subscription_id"
                                   domain="[('id', 'in', allowed_subscription_ids)]"
                                   context="{'default_partner_id': partner_id}"
                                   options="{'no_create_edit': True}"/>
                            <field name="verification_password"/>
                        </group>
                    </group>
                    <group string="Ubicación (se hereda de la suscripción — solo consulta)">
                        <field name="latitude" readonly="1"/>
                        <field name="longitude" readonly="1"/>
                        <div class="text-muted" colspan="2">
                            Las coordenadas se capturan y modifican en la <b>suscripción</b> (pestaña Instalación → Coordenadas del Sitio). Aquí solo se consultan.
                        </div>
                    </group>
                    <group string="Estado del Dispositivo">
                        <field name="last_communication"/>
                        <field name="expected_heartbeat_hours"/>
                        <field name="battery_level"/>
                        <field name="signal_strength"/>
                    </group>
                    <group string="Notas">
                        <field name="notes" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Zonas de Monitoreo">
                            <field name="zone_ids">
                                <list editable="bottom">
                                    <field name="zone_number" groups="base.group_system"/>
                                    <field name="zone_number" groups="!base.group_system" readonly="1"/>
                                    <field name="partition" groups="base.group_system"/>
                                    <field name="partition" groups="!base.group_system" readonly="1"/>
                                    <field name="name"/>
                                    <field name="camera_channel" string="Cámara"/>
                                    <field name="zone_type"/>
                                    <field name="is_bypassed"/>
                                </list>
                            </field>
                        </page>
                        <page string="Videoverificación" name="video_integration">
                            <group>
                                <group string="Configuración del DVR/NVR">
                                    <field name="has_video"/>
                                    <field name="connection_mode" invisible="not has_video"/>
                                    <field name="dvr_brand" invisible="not has_video" required="has_video"/>
                                    <field name="dvr_serial" invisible="connection_mode != 'cloud' or not has_video" required="connection_mode == 'cloud' and has_video"/>
                                    <field name="dvr_ip" invisible="connection_mode != 'direct' or not has_video" required="connection_mode == 'direct' and has_video"/>
                                    <field name="dvr_port" invisible="connection_mode != 'direct' or not has_video" required="connection_mode == 'direct' and has_video"/>
                                </group>
                                <group string="Credenciales y Acceso" invisible="not has_video">
                                    <field name="dvr_user" required="has_video"/>
                                    <field name="dvr_password" password="True" required="has_video"/>
                                    <field name="dvr_rtsp_port" invisible="connection_mode != 'direct'"/>
                                </group>
                            </group>
                            <div class="alert alert-success shadow-sm mt-3" role="alert" invisible="connection_mode != 'cloud' or not has_video">
                                <i class="fa fa-cloud me-2"/> <b>Modo Nube Activo:</b> 
                                No es necesario abrir puertos en el módem. La conexión se realizará vía P2P usando el número de serie.
                            </div>
                            <div class="alert alert-warning shadow-sm mt-3" role="alert" invisible="connection_mode != 'direct' or not has_video">
                                <i class="fa fa-warning me-2"/> <b>Nota de Seguridad:</b> 
                                Asegúrese de que el puerto HTTP esté redireccionado en el router del cliente.
                            </div>
                        </page>
                        <page string="Contactos de Emergencia">
                            <field name="contact_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="user_number" string="ID Panel"/>
                                    <field name="is_emergency_contact" string="Llamar?"/>
                                    <field name="name"/>
                                    <field name="phone"/>
                                    <field name="relation"/>
                                    <field name="email"/>
                                    <field name="notes"/>
                                    <field name="last_update" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Configuración de Eventos">
                            <group>
                                <group>
                                    <field name="template_id" placeholder="Seleccione una plantilla maestra..."/>
                                </group>
                                <group>
                                    <button name="action_apply_template" string="Cargar Plantilla" type="object" class="btn-primary" icon="fa-copy" invisible="not template_id"
                                            confirm="Esto REEMPLAZA la configuración de eventos de esta cuenta con la de la plantilla. Se perderán las personalizaciones actuales. ¿Continuar?"/>
                                </group>
                            </group>
                            <field name="alarm_config_ids">
                                <list editable="bottom" default_order="code_number">
                                    <field name="alarm_code_id" string="Código"/>
                                    <field name="code_description"/>
                                    <field name="event_category"/>
                                    <field name="code_number" column_invisible="1"/>
                                    <field name="priority_id" widget="badge"/>
                                    <field name="notify_email" string="Email"/>
                                    <field name="notify_telegram" string="Telegram"/>
                                    <field name="notify_whatsapp" string="WhatsApp"/>
                                </list>
                            </field>
                        </page>
                        <page string="Eventos de Alarma">
                            <field name="alarm_event_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="event_type"/>
                                    <field name="start_date"/>
                                    <field name="status"/>
                                    <field name="priority_id" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Señales de Alarma">
                            <field name="alarm_signal_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="signal_type"/>
                                    <field name="received_date"/>
                                    <field name="status"/>
                                    <field name="priority_id" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- TREE/LIST VIEW -->
    <record id="view_monitoring_device_list" model="ir.ui.view">
        <field name="name">sentinela.monitoring.device.list</field>
        <field name="model">sentinela.monitoring.device</field>
        <field name="arch" type="xml">
            <list string="Dispositivos de Monitoreo" decoration-info="status=='active'" decoration-muted="status=='inactive'" decoration-warning="status=='maintenance'" decoration-danger="status=='faulty' or status=='offline'">
                <field name="device_id"/>
                <field name="account_number"/>
                <field name="name"/>
                <field name="device_type"/>
                <field name="partner_id"/>
                <field name="status"/>
                <field name="last_communication"/>
                <field name="battery_level"/>
            </list>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_monitoring_device_search" model="ir.ui.view">
        <field name="name">sentinela.monitoring.device.search</field>
        <field name="model">sentinela.monitoring.device</field>
        <field name="arch" type="xml">
            <search string="Buscar Dispositivos">
                <field name="device_id"/>
                <field name="name"/>
                <field name="device_type"/>
                <field name="partner_id"/>
                <field name="status"/>
                <separator/>
                <filter name="active" string="Activos" domain="[('status', '=', 'active')]"/>
                <filter name="inactive" string="Inactivos" domain="[('status', '=', 'inactive')]"/>
                <filter name="faulty" string="Con Fallas" domain="[('status', '=', 'faulty')]"/>
                <filter name="offline" string="Desconectados" domain="[('status', '=', 'offline')]"/>
                <filter name="maintenance" string="En Mantenimiento" domain="[('status', '=', 'maintenance')]"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_monitoring_device" model="ir.actions.act_window">
        <field name="name">Dispositivos de Monitoreo</field>
        <field name="res_model">sentinela.monitoring.device</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>