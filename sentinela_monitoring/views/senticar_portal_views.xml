<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Layout para Clientes Senticar (Marca Blanca) -->
    <template id="senticar_layout" name="Senticar Client Layout">
        &lt;!DOCTYPE html&gt;
        <html lang="es">
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no, viewport-fit=cover"/>
                <meta name="apple-mobile-web-app-capable" content="yes"/>
                <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
                <link rel="manifest" href="/sentinela_monitoring/static/src/manifest_senticar.json"/>
                <link rel="apple-touch-icon" href="/sentinela_fsm/static/src/logo_senticar.png"/>
                <title>Senticar - Tu Rastreo Seguro</title>
                <t t-call-assets="web.assets_frontend" t-js="false"/>
                <style>
                    body { background: #1a1a1a; color: #fff; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto; margin: 0; padding: 0; height: 100vh; overflow: hidden; }
                    .senticar-header { height: 60px; background: #000; display: flex; align-items: center; padding: 0 20px; border-bottom: 1px solid #333; }
                    .senticar-content { height: calc(100vh - 60px); width: 100%; position: relative; }
                    .senticar-logo { height: 40px; }
                    .radar-iframe { width: 100%; height: 100%; border: none; }
                </style>
            </head>
            <body>
                <div class="senticar-header shadow">
                    <img src="/sentinela_fsm/static/src/logo_senticar.png" class="senticar-logo" alt="SENTICAR"/>
                    <div class="ms-auto">
                        <span class="small me-3 d-none d-md-inline">Hola, <t t-esc="user.name"/></span>
                        <a href="/web/session/logout" class="btn btn-sm btn-outline-danger">Salir</a>
                    </div>
                </div>
                <div class="senticar-content">
                    <t t-out="0"/>
                </div>
                <t t-call-assets="web.assets_frontend" t-css="false"/>
            </body>
        </html>
    </template>

    <!-- Vista del Radar Senticar para el Cliente -->
    <template id="senticar_radar_view" name="Radar Senticar">
        <t t-call="sentinela_monitoring.senticar_layout">
            <iframe t-att-src="traccar_url" class="radar-iframe" allow="geolocation"></iframe>
        </t>
    </template>
</odoo>
