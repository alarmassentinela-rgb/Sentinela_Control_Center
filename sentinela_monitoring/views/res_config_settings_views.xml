<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_monitoring" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.monitoring</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Monitoreo" string="Monitoreo" name="sentinela_monitoring">
                    <block title="Configuración de la Central" name="central_config">
                        <setting string="Numeración de Cuentas" help="Define el número de cuenta inicial para instalaciones nuevas.">
                            <div class="content-group">
                                <div class="mt16">
                                    <label for="monitoring_next_account_number" string="Siguiente Cuenta a Asignar"/>
                                    <field name="monitoring_next_account_number" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Servicio de Patrulla" help="Producto que se factura al despachar una patrulla autorizada (F2.6).">
                            <field name="patrol_service_product_id"/>
                        </setting>
                    </block>
                    <block title="Radar SentiCar / Traccar" name="traccar_config">
                        <setting string="Radar en el Dashboard" help="URL que se incrusta en el iframe del radar SentiCar.">
                            <field name="traccar_url"/>
                        </setting>
                        <setting string="API de Posiciones (rastreo en vivo / ETA)" help="Conexión a la API de Traccar que usa la Gestión de Servicios para ubicar patrulleros y calcular ETA.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="traccar_api_url" class="col-lg-4 o_light_label"/>
                                    <field name="traccar_api_url"/>
                                </div>
                                <div class="row">
                                    <label for="traccar_api_user" class="col-lg-4 o_light_label"/>
                                    <field name="traccar_api_user"/>
                                </div>
                                <div class="row">
                                    <label for="traccar_api_password" class="col-lg-4 o_light_label"/>
                                    <field name="traccar_api_password" password="True"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_monitoring_config_settings" model="ir.actions.act_window">
        <field name="name">Ajustes de Monitoreo</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'sentinela_monitoring'}</field>
    </record>
</odoo>
