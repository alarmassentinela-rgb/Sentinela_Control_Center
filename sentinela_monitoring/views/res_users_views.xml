<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_sip" model="ir.ui.view">
        <field name="name">res.users.form.inherit.sip</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="inside">
                <group string="Telefonía IP (Grandstream)">
                    <field name="sip_extension" placeholder="Ej. 101"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
