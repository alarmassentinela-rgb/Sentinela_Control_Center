<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- VISTA RADICAL PARA FORZAR CAMBIOS -->
    <record id='view_partner_form_sentinela_ultimate' model='ir.ui.view'>
        <field name='name'>res.partner.form.sentinela.ultimate</field>
        <field name='model'>res.partner</field>
        <field name='inherit_id' ref='base.view_partner_form'/>
        <field name="priority">1</field>
        <field name='arch' type='xml'>
            <!-- 1. Forzar ID Telegram en la parte superior del formulario (debajo del nombre) -->
            <xpath expr="//div[hasclass('oe_title')]" position="after">
                <div class="alert alert-info d-flex align-items-center gap-3 p-2 mb-2" role="status">
                    <i class="fa fa-paper-plane fa-2x text-primary"/>
                    <div class="flex-grow-1">
                        <label for="telegram_chat_id" string="ID TELEGRAM PARA NOTIFICACIONES" class="fw-bold"/>
                        <field name="telegram_chat_id" placeholder="Ej. 7965190381" class="w-100"/>
                    </div>
                    <div class="border-start ps-3">
                        <label for="is_patrol" string="PATRULLAJE"/>
                        <field name="is_patrol" widget="boolean_toggle"/>
                    </div>
                </div>
            </xpath>

            <!-- 2. Forzar traducción de la pestaña de cobranza buscando por texto -->
            <xpath expr="//page[@name='followup_tab']" position="attributes">
                <attribute name="string">Seguimiento de Pagos</attribute>
            </xpath>
        </field>
    </record>
            <xpath expr="//page[@name='internal_notes']" position='after'>
                <page string='Geolocalización' name="geo_location">
                    <group>
                        <group string='📍 UBICACIÓN MANUAL (Google Maps)'>
                            <p class="text-info small" colspan="2">
                                <i class="fa fa-info-circle"/> Pegue las coordenadas directamente desde Google Maps. <b>No se sobreescribirán por la dirección.</b>
                            </p>
                            <field name="partner_latitude" string="Latitud (GPS)"/>
                            <field name="partner_longitude" string="Longitud (GPS)"/>
                            
                            <button name="action_open_google_maps" 
                                    type="object" 
                                    string="VERIFICAR EN MAPA" 
                                    icon="fa-map-marker" 
                                    class="btn-primary mt-2"
                                    invisible="not partner_latitude or not partner_longitude"/>
                        </group>
                        <group string='Ayuda'>
                            <p class="text-muted small">
                                1. Busque el sitio en Google Maps.<br/>
                                2. De clic derecho y copie las coordenadas.<br/>
                                3. Péguelas en los campos de la izquierda y guarde.
                            </p>
                        </group>
                    </group>
                </page>
                <page string='Configuración Senticar' name="gps_config" invisible='not is_patrol'>
                    <group>
                        <group string='Vinculación Traccar'>
                            <field name='traccar_device_id'/>
                        </group>
                        <group string='Última Ubicación'>
                            <field name='last_gps_lat'/>
                            <field name='last_gps_lng'/>
                            <field name='last_gps_update'/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
