<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_subscription_form_monitoring_inherit" model="ir.ui.view">
        <field name="name">sentinela.subscription.form.monitoring.inherit</field>
        <field name="model">sentinela.subscription</field>
        <field name="inherit_id" ref="sentinela_subscriptions.view_sentinela_subscription_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="📡 Cuentas de Monitoreo" name="monitoring_accounts" invisible="service_type != 'alarm'">
                    <field name="monitoring_device_ids">
                        <list>
                            <field name="account_number"/>
                            <field name="name"/>
                            <field name="device_type"/>
                            <field name="status" widget="badge"/>
                        </list>
                    </field>
                </page>
                <page string="🚨 Historial de Alarmas" name="alarm_history" invisible="service_type != 'alarm'">
                    <field name="alarm_event_ids" readonly="1">
                        <list decoration-danger="priority == 'critical'" decoration-warning="priority == 'high'">
                            <field name="event_date"/>
                            <field name="account_number"/>
                            <field name="event_code"/>
                            <field name="description"/>
                            <field name="priority" widget="badge"/>
                        </list>
                    </field>
                </page>
                <page string="📞 Bitácora de Llamadas" name="call_logs" invisible="service_type != 'alarm'">
                    <field name="monitoring_call_ids" readonly="1">
                        <list>
                            <field name="event_date"/>
                            <field name="phone_number"/>
                            <field name="duration" widget="float_time"/>
                            <field name="status" widget="badge"/>
                            <field name="recording_url" widget="url" text="Escuchar"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
