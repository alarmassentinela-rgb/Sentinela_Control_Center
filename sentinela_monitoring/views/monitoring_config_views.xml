<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sentinela_monitoring_config_form" model="ir.ui.view">
        <field name="name">sentinela.monitoring.config.form</field>
        <field name="model">sentinela.monitoring.config</field>
        <field name="arch" type="xml">
            <form string="Configuración de la Central" create="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1>Ajustes Globales de Monitoreo</h1>
                    </div>
                    <group>
                        <group string="Alertas Sonoras Globales">
                            <label for="pending_event_sound" string="Sonido de Pendientes"/>
                            <div class="o_row">
                                <field name="pending_event_sound_filename" invisible="1"/>
                                <field name="pending_event_sound" widget="binary" filename="pending_event_sound_filename"/>
                            </div>
                            <p class="text-muted">Este audio sonará en bucle mientras existan eventos Activos o Pausados en el Dashboard.</p>
                        </group>
                        <group string="Tiempos y Respuesta">
                            <field name="refresh_interval"/>
                            <field name="auto_escalate_minutes"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sentinela_monitoring_config" model="ir.actions.act_window">
        <field name="name">Configuración de Central</field>
        <field name="res_model">sentinela.monitoring.config</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="res_id" eval="1"/> <!-- Siempre abrir el registro 1 -->
    </record>

    <menuitem id="menu_sentinela_monitoring_config_global"
              name="Ajustes de Central"
              parent="sentinela_monitoring.menu_monitoring_config"
              action="action_sentinela_monitoring_config"
              sequence="1"/>
</odoo>
