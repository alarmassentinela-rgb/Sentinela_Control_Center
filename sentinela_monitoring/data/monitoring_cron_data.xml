<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="action_sync_ucm_recordings" model="ir.actions.server">
            <field name="name">Sync UCM Recordings</field>
            <field name="model_id" ref="model_sentinela_alarm_event"/>
            <field name="state">code</field>
            <field name="code">model._cron_fetch_ucm_recordings()</field>
        </record>

        <record id="ir_cron_sync_ucm_recordings" model="ir.cron">
            <field name="name">Sentinela: Sincronización Automática de Grabaciones UCM</field>
            <field name="ir_actions_server_id" ref="action_sync_ucm_recordings"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

        <record id="action_detect_offline_panels" model="ir.actions.server">
            <field name="name">Detect Offline Panels</field>
            <field name="model_id" ref="model_sentinela_alarm_event"/>
            <field name="state">code</field>
            <field name="code">model._cron_detect_offline_panels()</field>
        </record>

        <record id="ir_cron_detect_offline_panels" model="ir.cron">
            <field name="name">Sentinela: Detección de Paneles Offline</field>
            <field name="ir_actions_server_id" ref="action_detect_offline_panels"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <record id="action_release_stale_locks" model="ir.actions.server">
            <field name="name">Release Stale Event Locks</field>
            <field name="model_id" ref="model_sentinela_alarm_event"/>
            <field name="state">code</field>
            <field name="code">model._cron_release_stale_locks()</field>
        </record>

        <record id="ir_cron_release_stale_locks" model="ir.cron">
            <field name="name">Sentinela: Liberación de Locks de Eventos Inactivos</field>
            <field name="ir_actions_server_id" ref="action_release_stale_locks"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">2</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

        <record id="action_telegram_poll_updates" model="ir.actions.server">
            <field name="name">Telegram: Poll Vinculación Clientes</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model._cron_telegram_poll_updates()</field>
        </record>

        <record id="ir_cron_telegram_poll_updates" model="ir.cron">
            <field name="name">Sentinela: Vinculación Telegram de Clientes (getUpdates)</field>
            <field name="ir_actions_server_id" ref="action_telegram_poll_updates"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
