# Copia a .env en el server y rellena. El .env NO se versiona (lleva secretos).

# ── Odoo (XML-RPC) ──
ODOO_URL=http://192.168.3.2:8070
ODOO_DB=Sentinela_V18
ODOO_USER=api_user
ODOO_PASSWORD=__SECRETO__

# ── Chatwoot ──
# URL interna del rails (alias de red docker), NO el dominio público.
CHATWOOT_BASE_URL=http://rails:3000
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1
# Token del AgentBot (se obtiene al crear el bot en Chatwoot).
CHATWOOT_BOT_TOKEN=__TOKEN_DEL_AGENTBOT__

# ── LLM (OpenRouter) ──
OPENROUTER_API_KEY=__SECRETO__
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
STATE_DB_PATH=/data/state.db
HISTORY_LIMIT=14

# ── Handoff / horario ──
HANDOFF_TEAM_ID=2
HANDOFF_KEYWORDS=asesor,humano,persona,ejecutivo,agente,representante,operador
TZ=America/Mexico_City
OFFICE_START=9
OFFICE_END=18
OFFICE_DAYS=0,1,2,3,4
INTAKE_LABEL=reporte-registrado
