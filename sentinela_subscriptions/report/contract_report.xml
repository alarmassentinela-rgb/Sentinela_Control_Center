<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_subscription_contract" model="report.paperformat">
        <field name="name">Subscription Contract Format</field>
        <field name="default" eval="True"/>
        <field name="format">Letter</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">8</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_subscription_contract" model="ir.actions.report">
        <field name="name">Contrato de Servicio</field>
        <field name="model">sentinela.subscription</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sentinela_subscriptions.report_subscription_contract</field>
        <field name="report_file">sentinela_subscriptions.report_subscription_contract</field>
        <field name="binding_model_id" ref="model_sentinela_subscription"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_subscription_contract"/>
    </record>

    <template id="report_subscription_contract">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <!-- HEADER: se repite automáticamente en cada página -->
                    <div class="header">
                        <table style="width: 100%; border-bottom: 2px solid #1f4e79; padding-bottom: 6px; border-collapse: collapse;">
                            <tr>
                                <td style="vertical-align: middle; text-align: left;">
                                    <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)"
                                         style="height: 45px; width: auto; max-width: 170px; vertical-align: middle; margin-right: 12px;"/>
                                    <span style="font-size: 16px; color: #1f4e79; font-weight: bold; vertical-align: middle;">CONTRATO DE SERVICIO</span>
                                </td>
                                <td style="text-align: right; font-size: 11px; color: #444; vertical-align: middle; white-space: nowrap;">
                                    Folio: <strong><t t-out="doc.name"/></strong><br/>
                                    Fecha: <strong><t t-out="doc.contract_date_human"/></strong>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <div class="page">
                        <style>
                            .contract-body {
                                text-align: justify;
                                font-size: 13px;
                                line-height: 1.5;
                                font-family: Arial, sans-serif;
                                margin: 0 20px;
                            }
                            .page-break-before {
                                page-break-before: always;
                                display: block;
                                margin-top: 20px;
                            }
                        </style>

                        <div class="contract-body">
                            <t t-out="doc.contract_body"/>
                        </div>

                        <!-- Sección de Servicios Incluidos / No Incluidos -->
                        <div class="contract-body" t-if="doc.service_inclusion_ids" style="margin-top: 30px;">
                            <h3 style="border-bottom: 2px solid #333; padding-bottom: 5px;">
                                SERVICIOS DEL CONTRATO
                            </h3>
                            <p style="margin-top: 10px;">
                                Esta suscripción cubre los servicios marcados como <strong>INCLUIDOS</strong>.
                                Los servicios <strong>NO INCLUIDOS</strong> pueden ser solicitados por evento
                                con el costo aparte indicado, previa autorización del cliente.
                            </p>
                            <table style="width: 100%; border-collapse: collapse; margin-top: 15px;">
                                <thead>
                                    <tr style="background-color: #f0f0f0;">
                                        <th style="border: 1px solid #999; padding: 8px; text-align: left;">Servicio</th>
                                        <th style="border: 1px solid #999; padding: 8px; text-align: center;">Estado</th>
                                        <th style="border: 1px solid #999; padding: 8px; text-align: right;">Precio por evento (sin IVA)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.service_inclusion_ids" t-as="inc">
                                        <td style="border: 1px solid #999; padding: 8px;">
                                            <span t-out="inc.service_id.name"/>
                                        </td>
                                        <td style="border: 1px solid #999; padding: 8px; text-align: center;">
                                            <strong t-if="inc.is_included" style="color: #1a7d2a;">INCLUIDO</strong>
                                            <strong t-else="" style="color: #b8002e;">NO INCLUIDO</strong>
                                        </td>
                                        <td style="border: 1px solid #999; padding: 8px; text-align: right;">
                                            <span t-if="inc.is_included">— (incluido en la mensualidad)</span>
                                            <span t-else="">
                                                $<span t-out="'{:,.2f}'.format(inc.extra_price)"/> MXN por evento
                                            </span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                            <p style="margin-top: 15px; font-size: 11px; color: #666;">
                                La autorización del costo por servicios no incluidos se realiza
                                vía Telegram o llamada al cliente. El servicio se factura aparte
                                en el siguiente ciclo de cobro.
                            </p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
