<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
        <!-- Cron existente: Generar Facturas -->
        <record id="ir_cron_generate_invoices" model="ir.cron">
            <field name="name">Suscripciones: Generar Pre-Facturas</field>
            <field name="model_id" ref="model_sentinela_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_generate_pre_invoices()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>

        </record>

        <!-- Cron: Revisar Prórrogas Vencidas -->
        <record id="ir_cron_check_extensions" model="ir.cron">
            <field name="name">Suscripciones: Revisar Prórrogas Vencidas</field>
            <field name="model_id" ref="model_sentinela_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_expired_extensions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
        </record>

        <!-- Cron: Auto-Suspensión por Facturas Vencidas (v18.0.1.3.1) -->
        <record id="ir_cron_auto_suspend_overdue" model="ir.cron">
            <field name="name">Suscripciones: Auto-Suspender por Facturas Vencidas</field>
            <field name="model_id" ref="model_sentinela_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_suspend_overdue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Cron: Recordatorios de Cobranza (v18.0.1.3.2) -->
        <record id="ir_cron_send_payment_reminders" model="ir.cron">
            <field name="name">Suscripciones: Enviar Recordatorios de Cobranza</field>
            <field name="model_id" ref="model_sentinela_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_payment_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Cron: Fin de Leasing (v18.0.1.3.4) -->
        <record id="ir_cron_check_leasing_end" model="ir.cron">
            <field name="name">Suscripciones: Revisar Fin de Leasing</field>
            <field name="model_id" ref="model_sentinela_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_leasing_end()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
</odoo>