<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sentinela_service_definition_list" model="ir.ui.view">
        <field name="name">sentinela.service.definition.list</field>
        <field name="model">sentinela.service.definition</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="price"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
</odoo>
