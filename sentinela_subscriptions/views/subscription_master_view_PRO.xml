<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sentinela_subscription_form_pro" model="ir.ui.view">
        <field name="name">sentinela.subscription.form.pro</field>
        <field name="model">sentinela.subscription</field>
        <field name="priority">0</field>
        <field name="arch" type="xml">
            <form string="Contrato de Servicio">
                <header>
                    <!-- FLUJO: Borrador → Pendiente Firma → Confirmado → Activo -->
                    <button name="action_request_signature" string="Enviar Contrato a Firmar" type="object" class="btn-primary"
                        invisible="state != 'draft'"/>
                    <button name="action_mark_contract_signed" string="Contrato Firmado (Papel)" type="object" class="btn-secondary"
                        invisible="state != 'pending_signature'"/>
                    <button name="action_activate" string="Activar Servicio" type="object" class="btn-success"
                        invisible="state != 'confirmed'"/>
                    <button name="action_generate_contract" string="Redactar Contrato" type="object" class="btn-primary" icon="fa-file-text-o"
                        invisible="state not in ['draft', 'pending_signature', 'confirmed']"/>
                    <button name="action_suspend" string="Suspender" type="object" class="btn-warning"
                        invisible="state != 'active'"/>
                    <button name="action_reactivate" string="Reconexión" type="object" class="btn-info"
                        invisible="state != 'suspension'"/>
                    <button name="action_open_extension_wizard" string="Otorgar Prórroga" type="object" class="btn-info"
                        invisible="state != 'suspension' or invoice_count == 0"/>
                    <button name="action_open_close_wizard" string="Baja Definitiva" type="object" class="btn-danger"
                        invisible="state in ('draft','cancelled')"/>
                    <button name="action_draft" string="Regresar a Borrador" type="object" class="btn-secondary"
                        invisible="state not in ['pending_signature', 'confirmed']"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,pending_signature,confirmed,active,suspension,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="invoice_count" widget="statinfo" string="Facturas"/>
                        </button>
                        <button name="action_view_fsm_orders" type="object" class="oe_stat_button" icon="fa-wrench">
                            <div class="o_stat_info"><span class="o_stat_text">Órdenes</span><span class="o_stat_text">Técnicas</span></div>
                        </button>
                    </div>

                    <!-- CAMPO OCULTO REQUERIDO POR INVISIBLE CONDITIONS -->
                    <field name="service_type" invisible="1"/>

                    <div class="oe_title">
                        <h1>
                            <span invisible="service_type != 'gps'" style="color: #e91e63;">🚀 SentiCar - </span>
                            <span invisible="service_type != 'alarm'" style="color: #2196f3;">🚀 Sentinela - </span>
                            <span invisible="service_type != 'internet'" style="color: #4caf50;">🚀 WavesInternet - </span>
                            <field name="name" readonly="1" class="oe_inline"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Titular">
                            <field name="partner_id" options="{'no_create': True}"/>
                            <field name="service_address_id" domain="['|', ('id', '=', partner_id), ('parent_id', '=', partner_id)]" options="{'no_create': True}"/>
                            <div class="o_address_format" colspan="2">
                                <field name="address_street" placeholder="Calle..." readonly="1"/>
                                <field name="address_street2" placeholder="Colonia..." readonly="1"/>
                                <div class="o_row">
                                    <field name="address_city" placeholder="Ciudad" readonly="1"/>
                                    <field name="address_state_id" options="{'no_open': True, 'no_create': True}" readonly="1"/>
                                    <field name="address_zip" placeholder="CP" readonly="1"/>
                                </div>
                            </div>
                        </group>
                        <group string="Configuración">
                            <field name="service_type"/>
                            <field name="product_id" options="{'no_create': True}"
                                domain="[('is_subscription', '=', True), ('service_type', '=', service_type)]"
                                help="Selecciona primero el tipo de servicio arriba para filtrar los planes."/>
                            <field name="price_unit" string="Precio Mensual"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- ═══ MONITOREO ═══ -->
                        <page string="📡 Monitoreo" name="monitoring" invisible="service_type != 'alarm'">
                            <group>
                                <group string="Central de Alarmas">
                                    <field name="monitoring_account_number"/>
                                    <field name="security_code" password="True"/>
                                    <field name="master_password" password="True"/>
                                </group>
                            </group>
                        </page>

                        <!-- ═══ GPS / SENTICAR ═══ -->
                        <page string="🚗 GPS" name="gps" invisible="service_type != 'gps'">
                            <group>
                                <group string="Dispositivo GPS">
                                    <field name="gps_imei"/>
                                    <field name="sim_iccid"/>
                                    <field name="equipment_brand" string="Marca Rastreador"/>
                                    <field name="equipment_model" string="Modelo Rastreador"/>
                                    <field name="equipment_serial" string="Número de Serie"/>
                                </group>
                                <group string="Vehículo">
                                    <field name="vehicle_brand" string="Marca"/>
                                    <field name="vehicle_model" string="Modelo"/>
                                    <field name="vehicle_year" string="Año"/>
                                    <field name="vehicle_color" string="Color"/>
                                    <field name="vehicle_plate" string="Placa"/>
                                    <field name="vehicle_vin" string="VIN / NIV"/>
                                </group>
                            </group>
                        </page>

                        <!-- ═══ FACTURACIÓN ═══ -->
                        <page string="📅 Facturación" name="billing">
                            <group>
                                <group string="Ciclo de Cobro">
                                    <field name="start_date" string="Fecha de Alta del Servicio"/>
                                    <field name="next_billing_date" string="Próxima Renovación"/>
                                    <field name="recurring_interval" string="Frecuencia de Cobro"/>
                                    <field name="payment_term_id" string="Días de Crédito" options="{'no_create': True}"/>
                                    <field name="extension_due_date" invisible="not extension_due_date"/>
                                </group>
                                <group string="Preferencias de Facturación">
                                    <field name="auto_invoice" widget="boolean_toggle"/>
                                    <field name="auto_send_mail" widget="boolean_toggle"/>
                                    <field name="days_to_suspend"
                                        help="Después de cuántos días vencida la factura el sistema corta el servicio. Default 5."/>
                                    <field name="is_forced_contract" widget="boolean_toggle"/>
                                    <field name="commitment_period" invisible="not is_forced_contract"/>
                                    <field name="commitment_end_date" readonly="1" invisible="not is_forced_contract"/>
                                    <field name="early_termination_fee" string="Penalización por Cancelar Antes de Plazo" invisible="not is_forced_contract"/>
                                </group>
                                <group string="Equipo / Propiedad">
                                    <field name="equipment_ownership"/>
                                    <field name="plan_after_leasing_id" options="{'no_create': True}"
                                        invisible="equipment_ownership != 'leasing'"
                                        required="equipment_ownership == 'leasing'"/>
                                </group>
                            </group>
                        </page>

                        <!-- ═══ DATOS TÉCNICOS / EQUIPAMIENTO ═══ -->
                        <page string="🔧 Datos Técnicos" name="equipment">
                            <group>
                                <!-- ESTADO TÉCNICO (solo alarmas) -->
                                <group string="Estado Técnico" invisible="service_type != 'alarm'">
                                    <field name="technical_state" readonly="1"/>
                                    <field name="technical_state_date" readonly="1"/>
                                </group>
                                <!-- PANEL DE ALARMA (solo alarmas) -->
                                <group string="Panel de Alarma" invisible="service_type != 'alarm'">
                                    <field name="equipment_brand" string="Marca Panel"/>
                                    <field name="equipment_model" string="Modelo Panel"/>
                                    <field name="equipment_serial" string="Número de Serie"/>
                                </group>
                                <!-- CONECTIVIDAD INTERNET -->
                                <group string="Conectividad" invisible="service_type != 'internet'">
                                    <field name="router_id" options="{'no_create': True}" required="service_type == 'internet'"/>
                                    <field name="product_mikrotik_profile_id" invisible="1"/>
                                    <field name="mikrotik_profile_id" options="{'no_create': True}"
                                        required="service_type == 'internet' and internet_mgmt_mode == 'pppoe'"
                                        readonly="product_mikrotik_profile_id"
                                        help="Si el plan contratado tiene perfil MikroTik asignado, se hereda automáticamente y no se puede modificar. Si el plan no tiene perfil, selecciona uno manualmente."/>
                                    <field name="internet_mgmt_mode"/>
                                    <field name="ip_address" string="IP Asignada"/>
                                    <field name="gateway_address" invisible="internet_mgmt_mode != 'static'"/>
                                    <field name="subnet_mask" invisible="internet_mgmt_mode != 'static'"/>
                                    <field name="vlan_id" invisible="internet_mgmt_mode != 'static'"/>
                                    <field name="sim_iccid" invisible="internet_mgmt_mode != 'dhcp'"/>
                                </group>
                                <!-- CREDENCIALES PPPOE -->
                                <group string="Credenciales PPPoE" invisible="service_type != 'internet' or internet_mgmt_mode != 'pppoe'">
                                    <field name="pppoe_server_name" readonly="1"/>
                                    <label for="pppoe_user"/>
                                    <div class="o_row">
                                        <field name="pppoe_user" nolabel="1"/>
                                        <button name="toggle_pppoe_user_lock" type="object" class="btn-link p-0 ms-1"
                                            title="Bloquear/Desbloquear" icon="fa-lock" invisible="not pppoe_user_locked"/>
                                        <button name="toggle_pppoe_user_lock" type="object" class="btn-link p-0 ms-1"
                                            title="Bloquear/Desbloquear" icon="fa-unlock" invisible="pppoe_user_locked"/>
                                    </div>
                                    <label for="pppoe_password"/>
                                    <div class="o_row">
                                        <field name="pppoe_password" nolabel="1" password="True"/>
                                        <button name="toggle_pppoe_password_lock" type="object" class="btn-link p-0 ms-1"
                                            title="Bloquear/Desbloquear" icon="fa-lock" invisible="not pppoe_password_locked"/>
                                        <button name="toggle_pppoe_password_lock" type="object" class="btn-link p-0 ms-1"
                                            title="Bloquear/Desbloquear" icon="fa-unlock" invisible="pppoe_password_locked"/>
                                    </div>
                                    <button name="action_alta_router_pppoe" type="object" class="btn-primary" icon="fa-plus-circle"
                                        string="Dar de alta en router (asigna cta + crea secret)"
                                        confirm="Se asignará el siguiente usuario cta libre del router y se creará su secret PPPoE con el password capturado. ¿Continuar?"/>
                                </group>
                                <!-- HARDWARE INTERNET WISP (solo internet) -->
                                <group string="Antena CPE Exterior (Ubiquiti)" invisible="service_type != 'internet'">
                                    <field name="antenna_product_id" options="{'no_create': True}" placeholder="Buscar del catálogo (Ubiquiti/MikroTik)..."/>
                                    <field name="antenna_brand" string="Marca Antena"/>
                                    <field name="antenna_model" string="Modelo Antena"/>
                                    <field name="antenna_serial" string="Número de Serie"/>
                                </group>
                                <group string="Router / Módem WiFi (Interior)" invisible="service_type != 'internet'">
                                    <field name="router_product_id" options="{'no_create': True}" placeholder="Buscar del catálogo (cualquier marca)..."/>
                                    <field name="equipment_brand" string="Marca Router"/>
                                    <field name="equipment_model" string="Modelo Router"/>
                                    <field name="equipment_serial" string="Número de Serie"/>
                                </group>
                                <group string="Módem Cliente" invisible="service_type != 'internet'">
                                    <field name="modem_user" string="Usuario"/>
                                    <field name="modem_password" string="Contraseña"/>
                                </group>
                            </group>
                            <div class="o_row mt-2" invisible="service_type != 'internet'">
                                <button name="action_request_pppoe_credentials" string="Solicitar Credenciales PPPoE"
                                    type="object" class="btn-secondary me-2"
                                    invisible="internet_mgmt_mode != 'pppoe' or state not in ['draft','pending_signature','confirmed']"/>
                                <button name="action_open_ping_wizard" string="Ping / Diagnóstico"
                                    type="object" class="btn-secondary me-2" invisible="state != 'active'"/>
                                <button name="action_view_traffic" string="Ver Tráfico"
                                    type="object" class="btn-info me-2" invisible="state != 'active'"/>
                                <button name="action_check_connection" string="Verificar Conexión"
                                    type="object" class="btn-secondary me-2" invisible="state != 'active'"/>
                                <button name="action_signal_antenna" string="📡 Señal Antena"
                                    type="object" class="btn-warning" invisible="state != 'active'"/>
                            </div>
                            <!-- PANEL SEÑAL DE ANTENA -->
                            <group string="📡 Señal de la Antena CPE" invisible="not antenna_signal_updated">
                                <group>
                                    <field name="antenna_signal_quality"/>
                                    <field name="antenna_signal_dbm"/>
                                    <field name="antenna_snr"/>
                                </group>
                                <group>
                                    <field name="antenna_link_rate"/>
                                    <field name="antenna_distance"/>
                                    <field name="antenna_signal_updated"/>
                                </group>
                            </group>
                            <!-- GRÁFICA DE TRÁFICO EN VIVO (animada, móvil-friendly) -->
                            <separator string="📊 Tráfico en Vivo" invisible="state != 'active' or service_type != 'internet'"/>
                            <field name="live_traffic_graph" widget="traffic_graph" nolabel="1"
                                invisible="state != 'active' or service_type != 'internet'"/>
                        </page>

                        <!-- ═══ INSTALACIÓN ═══ -->
                        <page string="📍 Instalación" name="installation">
                            <group>
                                <group string="Dirección del Servicio">
                                    <field name="address_street" string="Calle y Número"/>
                                    <field name="address_street2" string="Colonia / Sector"/>
                                    <field name="address_city" string="Ciudad"/>
                                    <field name="address_state_id" string="Estado"/>
                                    <field name="address_zip" string="Código Postal"/>
                                </group>
                                <group string="Coordenadas del Sitio">
                                    <field name="latitude" string="Latitud"/>
                                    <field name="longitude" string="Longitud"/>
                                    <field name="location_notes" string="Notas de Acceso" placeholder="Referencias de acceso, llaves, etc."/>
                                    <button name="action_geocode_address" type="object"
                                            string="📍 Obtener Coordenadas de la Dirección"
                                            class="btn-secondary"
                                            help="Llena automáticamente latitud y longitud a partir de la dirección del servicio."/>
                                    <button name="action_open_map" type="object"
                                            string="🗺️ Abrir en Google Maps"
                                            class="btn-link"
                                            invisible="not latitude or not longitude"/>
                                </group>
                            </group>
                        </page>

                        <!-- ═══ CONTRATO DIGITAL ═══ -->
                        <page string="📄 Contrato Digital" name="contract">
                            <div class="alert alert-info mb-2" role="alert">
                                <strong>Estado: </strong>
                                <field name="contract_status_label" readonly="1" nolabel="1" class="oe_inline"/>
                            </div>
                            <div class="o_row mb-3">
                                <button name="action_generate_contract" type="object"
                                        string="📝 Redactar / Actualizar Contrato"
                                        class="btn-primary"
                                        invisible="state in ('cancelled','closed')"/>
                                <button name="action_print_contract" type="object"
                                        string="📥 Descargar PDF"
                                        class="btn-secondary"
                                        invisible="not contract_body"/>
                                <button name="action_send_contract_for_signature" type="object"
                                        string="📤 Enviar para Firma Electrónica"
                                        class="btn-success"
                                        invisible="contract_signed or sign_state == 'signed' or not contract_body"
                                        confirm="¿Enviar el contrato al email del cliente para firma electrónica?"/>
                                <button name="action_view_sign_document" type="object"
                                        string="👁 Abrir Documento de Firma"
                                        class="btn-secondary"
                                        invisible="not sign_document_id"/>
                                <button name="action_mark_contract_signed" type="object"
                                        string="✍ Marcar como Firmado en Papel"
                                        class="btn-link"
                                        invisible="contract_signed or sign_state == 'signed'"/>
                            </div>
                            <group>
                                <group string="Información de la Firma">
                                    <field name="contract_template_id" readonly="1"/>
                                    <field name="contract_date"/>
                                    <field name="sign_document_id" readonly="1" options="{'no_create': True}"/>
                                    <field name="sign_state" widget="badge"
                                           decoration-info="sign_state == 'sent'"
                                           decoration-success="sign_state == 'signed'"
                                           decoration-muted="sign_state == 'draft'"
                                           decoration-danger="sign_state == 'cancel'"
                                           invisible="not sign_document_id"/>
                                    <field name="contract_signed" widget="boolean_toggle" readonly="1"/>
                                </group>
                            </group>
                            <separator string="📄 Vista Previa del Contrato"/>
                            <field name="contract_body_html" widget="html" options="{'safe': True}" nolabel="1"/>
                        </page>

                        <!-- ═══ NOTAS ═══ -->
                        <page string="📝 Notas" name="notes">
                            <field name="description" widget="html" placeholder="Notas internas..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
