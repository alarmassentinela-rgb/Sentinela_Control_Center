<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_subscriptions" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.subscriptions</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="95"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Suscripciones" string="Suscripciones" name="sentinela_subscriptions">
                    <block title="⚙️ Automatización de Facturación y Cobranza" name="billing_crons_config">
                        <setting id="cron_generate" help="Crea las pre-facturas del ciclo (recomendado: diario, 1:00 am).">
                            <field name="auto_cron_generate" widget="boolean_toggle"/>
                            <div class="text-muted small mt4"><field name="auto_cron_generate_info" nolabel="1" readonly="1"/></div>
                        </setting>
                        <setting id="cron_stamp" help="Timbra las facturas nuevas en Prodigia y se las envía al cliente (cada hora).">
                            <field name="auto_cron_stamp" widget="boolean_toggle"/>
                            <div class="text-muted small mt4"><field name="auto_cron_stamp_info" nolabel="1" readonly="1"/></div>
                        </setting>
                        <setting id="cron_suspend" help="Suspende el servicio a clientes con facturas vencidas (diario).">
                            <field name="auto_cron_suspend" widget="boolean_toggle"/>
                            <div class="text-muted small mt4"><field name="auto_cron_suspend_info" nolabel="1" readonly="1"/></div>
                        </setting>
                        <setting id="cron_reminders" help="Envía recordatorios de cobranza al cliente (diario).">
                            <field name="auto_cron_reminders" widget="boolean_toggle"/>
                            <div class="text-muted small mt4"><field name="auto_cron_reminders_info" nolabel="1" readonly="1"/></div>
                        </setting>
                        <setting id="cron_leasing" help="Revisa el fin de leasing de equipos (diario).">
                            <field name="auto_cron_leasing" widget="boolean_toggle"/>
                            <div class="text-muted small mt4"><field name="auto_cron_leasing_info" nolabel="1" readonly="1"/></div>
                        </setting>
                    </block>
                    <block title="Conectividad Connecta / floLIVE" name="connecta_config">
                        <setting string="Credenciales de API" help="Configura el acceso para el monitoreo de tarjetas SIM (GPS).">
                            <div class="content-group">
                                <div class="mt16">
                                    <label for="connecta_client_id" string="Client ID (Correo)"/>
                                    <field name="connecta_client_id" class="oe_inline"/>
                                </div>
                                <div class="mt8">
                                    <label for="connecta_access_token" string="Access Token (Contraseña)"/>
                                    <field name="connecta_access_token" password="True" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="SentiCar / Traccar (GPS)" name="senticar_config">
                        <setting string="API y panel" help="Acceso de la integración a SentiCar/Traccar y URLs públicas.">
                            <div class="content-group">
                                <div class="mt16">
                                    <label for="traccar_api_url" string="URL API (LAN)"/>
                                    <field name="traccar_api_url" class="oe_inline"/>
                                </div>
                                <div class="mt8">
                                    <label for="traccar_api_user" string="Usuario API"/>
                                    <field name="traccar_api_user" class="oe_inline"/>
                                </div>
                                <div class="mt8">
                                    <label for="traccar_api_password" string="Contraseña API"/>
                                    <field name="traccar_api_password" password="True" class="oe_inline"/>
                                </div>
                                <div class="mt8">
                                    <label for="senticar_public_url" string="URL pública del panel"/>
                                    <field name="senticar_public_url" class="oe_inline"/>
                                </div>
                                <div class="mt8">
                                    <label for="senticar_portal_base" string="Base portal transportista"/>
                                    <field name="senticar_portal_base" class="oe_inline"/>
                                </div>
                                <div class="mt8">
                                    <label for="senticar_admin_user_id" string="IDs de admins (ej. 1,5)"/>
                                    <field name="senticar_admin_user_id" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Reconciliación y links" help="Comportamiento del cron de reconciliación y de los links de rastreo.">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="senticar_reconcile_autoheal"/>
                                    <label for="senticar_reconcile_autoheal" string="Auto-corregir desajustes en la reconciliación"/>
                                </div>
                                <div class="mt8">
                                    <label for="senticar_share_max_hours" string="Máx. horas de link de rastreo"/>
                                    <field name="senticar_share_max_hours" class="oe_inline"/>
                                </div>
                                <div class="mt8">
                                    <label for="senticar_root_group" string="Grupo raíz (paraguas)"/>
                                    <field name="senticar_root_group" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_sentinela_subscription_config_settings" model="ir.actions.act_window">
        <field name="name">Ajustes de Suscripciones</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'sentinela_subscriptions'}</field>
    </record>
</odoo>
