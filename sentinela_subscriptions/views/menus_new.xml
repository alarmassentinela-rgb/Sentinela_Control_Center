<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ACCIÓN DE CONTRATOS -->
    <record id="action_sentinela_subscription" model="ir.actions.act_window">
        <field name="name">Suscripciones Sentinela</field>
        <field name="res_model">sentinela.subscription</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENÚ RAÍZ -->
    <menuitem id="menu_sentinela_subscription_root"
        name="Suscripciones"
        web_icon="sentinela_subscriptions,static/description/icon.png"
        sequence="10"/>

    <!-- ACCESO DIRECTO A CONTRATOS -->
    <menuitem id="menu_sentinela_subscription_list"
        name="Contratos"
        parent="menu_sentinela_subscription_root"
        action="action_sentinela_subscription"
        sequence="10"/>

    <!-- MENÚ DE CONFIGURACIÓN -->
    <menuitem id="menu_sentinela_subscription_config"
        name="Configuración"
        parent="menu_sentinela_subscription_root"
        sequence="100"/>
</odoo>
