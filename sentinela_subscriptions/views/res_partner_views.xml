<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_subscription" model="ir.ui.view">
        <field name="name">res.partner.form.subscription</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">40</field>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button class="oe_stat_button" type="object" name="action_view_subscriptions"
                    icon="fa-refresh" invisible="False">
                    <field string="Suscripciones" name="subscription_count" widget="statinfo"/>
                </button>
            </div>
            <page name="mexico_tax" position="inside">
                <group string="Condiciones de Pago y Facturación" name="sentinela_config_global">
                    <group string="Especificaciones de Condiciones de Venta">
                        <field name="invoice_grouping_method"/>
                        <field name="invoice_show_branches" widget="boolean_toggle"
                               invisible="invoice_grouping_method != 'global'"/>
                        <label for="invoice_payment_condition"/>
                        <div class="o_row">
                            <field name="invoice_payment_condition"/>
                            <field name="invoice_payment_condition_text" invisible="invoice_payment_condition != 'otro'" placeholder="Indique condición..."/>
                        </div>
                        <field name="invoice_payment_form"/>
                        <field name="invoice_bank_account"/>
                        <field name="invoice_payment_method"/>
                        <field name="invoice_zip"/>
                    </group>
                    <group string="Comprobante Fiscal">
                        <field name="requiere_factura" widget="boolean_toggle"/>
                        <field name="invoice_cc_partner_ids"
                            widget="many2many_tags"
                            domain="[('id', 'child_of', id), ('id', '!=', id)]"
                            options="{'no_create_edit': True}"
                            placeholder="Contactos que reciben copia de TODAS sus facturas (global/sucursal)"/>
                    </group>
                </group>
            </page>
            
            <!-- Teléfono + Extensión en UN solo renglón (reemplaza el campo phone para no descuadrar el grupo) -->
            <xpath expr="//field[@name='phone']" position="replace">
                <label for="phone" string="Teléfono"/>
                <div class="o_row">
                    <field name="phone" class="oe_inline"/>
                    <span class="mx-1 text-muted">ext.</span>
                    <field name="phone_extension" class="oe_inline" placeholder="0000" style="max-width:48px;"/>
                </div>
            </xpath>
            <!-- Celular sin widget phone (quita el llamar/SMS al pasar el cursor) -->
            <xpath expr="//field[@name='mobile']" position="attributes">
                <attribute name="widget"></attribute>
            </xpath>
            <!-- NOTA: la sección de "Teléfonos adicionales" (phone_line_ids / res.partner.phone)
                 se retiró de la UI por ahora (no dejaba agregar en el navegador del usuario).
                 El modelo y el campo siguen en el código, dormidos, para retomarlo después. -->


            <!-- Force translations for standard fields if missing -->
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="string">Vendedor</attribute>
            </xpath>
            <xpath expr="//field[@name='property_payment_term_id']" position="attributes">
                <attribute name="string">Plazos de Pago (Venta)</attribute>
            </xpath>
            <xpath expr="//field[@name='property_supplier_payment_term_id']" position="attributes">
                <attribute name="string">Plazos de Pago (Compra)</attribute>
            </xpath>
        </field>
    </record>
</odoo>
