<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_subscription_advance_global_wizard_form" model="ir.ui.view">
        <field name="name">sentinela.subscription.advance.global.wizard.form</field>
        <field name="model">sentinela.subscription.advance.global.wizard</field>
        <field name="arch" type="xml">
            <form string="Cobro Adelantado Global del Cliente">
                <field name="currency_id" invisible="1"/>
                <group>
                    <group>
                        <field name="partner_id" options="{'no_create': True}" readonly="context.get('default_partner_id')"/>
                        <field name="n_ciclos"/>
                    </group>
                    <group>
                        <field name="sub_count"/>
                        <field name="estimated_total" widget="monetary"/>
                    </group>
                </group>
                <div class="alert alert-warning" role="alert" invisible="not mixed_intervals">
                    <field name="mixed_intervals" invisible="1"/>
                    ⚠️ Este cliente tiene suscripciones con <strong>distintos intervalos</strong>.
                    Cada una avanza <strong>n_ciclos × su propio intervalo</strong>: revisa la columna
                    "Próx. cobro TRAS adelanto" por suscripción antes de confirmar.
                </div>
                <field name="preview_html" nolabel="1" readonly="1"/>
                <div class="alert alert-info" role="alert">
                    Se generará UNA <strong>factura BORRADOR consolidada</strong> con todas las
                    suscripciones del cliente. <strong>Al publicarla</strong>, la próxima fecha de cobro
                    de cada suscripción avanzará los ciclos indicados, para que la facturación recurrente
                    no las vuelva a facturar hasta la nueva fecha. Si la factura se cancela, el ciclo
                    de todas regresa solo (reversa total).
                </div>
                <footer>
                    <button name="action_create_invoice" string="Generar Factura Borrador" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
