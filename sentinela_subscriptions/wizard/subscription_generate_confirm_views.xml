<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sentinela_subscription_generate_confirm_form" model="ir.ui.view">
        <field name="name">sentinela.subscription.generate.confirm.form</field>
        <field name="model">sentinela.subscription.generate.confirm</field>
        <field name="arch" type="xml">
            <form string="Confirmar Regeneración">
                <field name="message" readonly="1" widget="text" class="text-center font-weight-bold"/>
                <footer class="justify-content-center">
                    <button name="action_confirm" string="Sí, Generar Nuevo" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
