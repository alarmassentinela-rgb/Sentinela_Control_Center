<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_subscription_advance_wizard_form" model="ir.ui.view">
        <field name="name">sentinela.subscription.advance.wizard.form</field>
        <field name="model">sentinela.subscription.advance.wizard</field>
        <field name="arch" type="xml">
            <form string="Cobro de Meses por Adelantado">
                <group>
                    <field name="subscription_id" invisible="1"/>
                    <group>
                        <field name="months"/>
                        <field name="price_unit" widget="monetary"/>
                    </group>
                    <group>
                        <field name="period_start"/>
                        <field name="period_end"/>
                        <field name="estimated_total" widget="monetary"/>
                    </group>
                </group>
                <div class="alert alert-info" role="alert">
                    Se generará una <strong>factura BORRADOR</strong> por los meses indicados (cantidad × tarifa mensual),
                    lista para revisar y timbrar. <strong>Al publicarla</strong>, la próxima fecha de cobro de la
                    suscripción avanzará esos meses automáticamente, para que el cobro recurrente no los vuelva a facturar.
                    Si la factura se cancela, el ciclo regresa solo.
                </div>
                <footer>
                    <button name="action_create_invoice" string="Generar Factura Borrador" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
