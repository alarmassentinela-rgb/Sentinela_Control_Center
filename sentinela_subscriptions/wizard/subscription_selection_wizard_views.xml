<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sentinela_subscription_selection_wizard_form" model="ir.ui.view">
        <field name="name">sentinela.subscription.selection.wizard.form</field>
        <field name="model">sentinela.subscription.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Seleccionar Equipo de la Cotización">
                <sheet>
                    <group>
                        <field name="subscription_id" invisible="1"/>
                        <field name="sale_order_id" readonly="1"/>
                        <field name="line_ids" invisible="1"/>
                        <field name="selected_line_id" widget="radio"/>
                    </group>
                    <p class="text-muted">
                        Se han encontrado múltiples equipos en la cotización. Por favor, seleccione cuál corresponde a este contrato.
                    </p>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Vincular Seleccionado" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
