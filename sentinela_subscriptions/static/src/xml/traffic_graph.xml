<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="sentinela_subscriptions.TrafficGraph" owl="1">
        <div class="o_traffic_graph_container" style="width: 100%; padding: 8px; background: #f9f9f9; border: 1px solid #ddd; border-radius: 6px;">
            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap">
                <span class="badge rounded-pill text-bg-info me-1">IP: <t t-esc="state.current_ip"/></span>
                <span class="badge rounded-pill text-bg-success me-1">⬇ <t t-esc="state.rx_speed"/> Mbps</span>
                <span class="badge rounded-pill text-bg-primary me-1">⬆ <t t-esc="state.tx_speed"/> Mbps</span>
                <span class="badge rounded-pill text-bg-secondary"><t t-esc="state.status"/></span>
            </div>
            <div style="position: relative; height: 240px;">
                <canvas t-ref="canvas"></canvas>
            </div>
        </div>
    </t>
</templates>
