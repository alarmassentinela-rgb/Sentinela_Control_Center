# COC Gateway — variables de entorno (copiar a .env, NO commitear .env)
COC_LOG_LEVEL=INFO

# Odoo (sentinela_api) — el gateway es el unico que habla con Odoo (LAN)
COC_ODOO_BASE_URL=http://192.168.3.2:8069
COC_ODOO_DB=V18
# Cuenta de servicio (permisos minimos). En prod: vault, no .env plano.
COC_ODOO_SERVICE_LOGIN=
COC_ODOO_SERVICE_PASSWORD=

# Almacen propio del gateway (identidad/OTP/sesiones) — Postgres dedicado
COC_GATEWAY_DB_URL=postgresql+psycopg://coc:coc@localhost:5432/coc_gateway

# Seguridad (WS-5)
COC_JWT_SECRET=change-me
COC_JWT_ACCESS_TTL_MIN=15
COC_JWT_REFRESH_TTL_DAYS=30
COC_OTP_TTL_SEC=300
COC_OTP_MAX_ATTEMPTS=5

# Mensajeria WhatsApp (OTP transaccional) — driver EvoApi (WS-5)
COC_WA_DRIVER=evoapi
COC_WA_BASE_URL=
COC_WA_API_KEY=
COC_WA_INSTANCE=

# Pagos — Stripe (Sprint 2 / Cobranza · MODO TEST). Placeholders; claves reales SOLO en .env (no se commitean).
# Primer PaymentAdapter del Motor de Pago (historia S2-006); el Motor depende de la interfaz, no de Stripe.
COC_STRIPE_SECRET_KEY=sk_test_xxx          # clave secreta de prueba (sk_test_...)
COC_STRIPE_WEBHOOK_SECRET=whsec_test_xxx   # firma del webhook de confirmacion (S2-008)
COC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx     # clave publica (Stripe.js en la SPA)
