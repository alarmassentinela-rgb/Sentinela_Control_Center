# ============================================================
# GOLFBOOKVIP.COM — Variables de Entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a git
# ============================================================

# ── Entorno ──────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
APP_NAME=golfbookvip
APP_VERSION=1.0.0
BASE_URL=https://api.golfbookvip.com

# ── Base de Datos ─────────────────────────────────────────
POSTGRES_DB=golfbookvip
POSTGRES_USER=golfuser
POSTGRES_PASSWORD=CAMBIA_ESTA_CLAVE_SEGURA
DATABASE_URL=postgresql+asyncpg://golfuser:CAMBIA_ESTA_CLAVE_SEGURA@db:5432/golfbookvip

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIA_ESTA_CLAVE_REDIS
REDIS_URL=redis://:CAMBIA_ESTA_CLAVE_REDIS@redis:6379/0

# ── JWT ───────────────────────────────────────────────────
SECRET_KEY=GENERA_UNA_CLAVE_ALEATORIA_DE_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Stripe (Pagos) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Firebase (Push Notifications) ────────────────────────
FIREBASE_CREDENTIALS=/app/firebase-credentials.json
FIREBASE_PROJECT_ID=golfbookvip

# ── Email ─────────────────────────────────────────────────
MAIL_USERNAME=noreply@golfbookvip.com
MAIL_PASSWORD=
MAIL_FROM=noreply@golfbookvip.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=GolfBookVIP

# ── Storage de Media (S3 o local) ─────────────────────────
STORAGE_TYPE=local           # 'local' o 's3'
MEDIA_ROOT=/app/media
MEDIA_URL=https://api.golfbookvip.com/media/

# S3 (si STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=golfbookvip-media
AWS_REGION=us-east-1

# ── Clima API (OpenWeatherMap) ────────────────────────────
OPENWEATHER_API_KEY=

# ── Sentry (Monitoreo de errores) ────────────────────────
SENTRY_DSN=

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=["https://golfbookvip.com","https://www.golfbookvip.com"]
