<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_invoice_sentinela" model="report.paperformat">
        <field name="name">Sentinela Invoice Letter</field>
        <field name="default" eval="True"/>
        <field name="format">Letter</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>

    <record id="account.account_invoices" model="ir.actions.report">
        <field name="paperformat_id" ref="paperformat_invoice_sentinela"/>
    </record>

    <template id="report_invoice_cfdi_section" inherit_id="account.report_invoice_document">
        <xpath expr="//t[@t-call='web.external_layout']" position="replace">
            <t t-call="web.basic_layout">
                <t t-set="o" t-value="o.with_context(lang=lang)"/>
                <t t-set="logo_b64" t-value="o._get_company_logo_b64()"/>
                <!-- Timbrada (con UUID CFDI) = FACTURA; sin timbrar = REMISIÓN (uso interno) -->
                <t t-set="doc_label" t-value="'FACTURA' if o.cfdi_uuid else 'REMISIÓN'"/>
                <!-- Tasa de IVA REAL de la factura (8% frontera u 16%), no hardcodear -->
                <t t-set="_taxed_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.display_type == 'product' and l.tax_ids)"/>
                <t t-set="iva_rate" t-value="int(round(_taxed_lines[0].tax_ids[0].amount)) if _taxed_lines else 16"/>
                <!-- Emisor: razón social fiscal (persona física = nombre legal). La marca "Sentinela" queda en el logo. -->
                <t t-set="emisor_name" t-value="o.company_id.l10n_mx_edi_fiscal_name or o.company_id.name"/>
                <!-- Solo es timbre de PRUEBA si el PAC está en modo prueba; en producción real NO debe aparecer la leyenda -->
                <t t-set="is_test" t-value="o.env['ir.config_parameter'].sudo().get_param('sentinela_cfdi_prodigia.test_mode', 'True').lower() == 'true'"/>
                <div class="page" style="font-family: Arial, sans-serif; font-size: 12px; color: #222;">

                    <!-- ENCABEZADO (divs display:table para evitar bordes por defecto del <table>) -->
                    <div style="display:table; width:100%; margin-bottom:6px;">
                        <!-- Logo centrado, con margen para no tocar el borde -->
                        <div style="display:table-cell; width:30%; vertical-align:middle; text-align:center; padding:6px 14px;">
                            <img t-if="logo_b64"
                                 t-att-src="'data:image/png;base64,' + logo_b64"
                                 style="max-height:68px; max-width:205px; height:auto; margin:0 auto; display:inline-block;"/>
                            <span t-else="" style="font-size:18px; font-weight:bold; color:#1a3a5c;">
                                <t t-esc="emisor_name"/>
                            </span>
                        </div>
                        <!-- Datos de la empresa (más grandes) -->
                        <div style="display:table-cell; width:34%; vertical-align:middle; padding-left:14px; font-size:12px; line-height:1.7; color:#333;">
                            <div style="font-weight:bold; font-size:19px; color:#1a3a5c; margin-bottom:3px;"><t t-esc="emisor_name"/></div>
                            <div><t t-esc="o.company_id.street or ''"/><t t-if="o.company_id.street2">, <t t-esc="o.company_id.street2"/></t></div>
                            <div><t t-esc="o.company_id.city or ''"/><t t-if="o.company_id.state_id">, <t t-esc="o.company_id.state_id.name"/></t> <t t-esc="o.company_id.zip or ''"/></div>
                            <div><strong>RFC:</strong> <t t-esc="o.company_id.vat or ''"/></div>
                            <div><strong>Régimen Fiscal:</strong> <t t-esc="o.company_id.l10n_mx_edi_fiscal_regime or ''"/></div>
                            <div t-if="o.company_id.phone"><strong>Tel:</strong> <t t-esc="o.company_id.phone"/></div>
                            <div><strong>Email:</strong> cobranza@sentinela.com.mx</div>
                        </div>
                        <!-- Caja del documento -->
                        <div style="display:table-cell; width:36%; vertical-align:middle; text-align:right;">
                            <div style="border:2px solid #1a3a5c; border-radius:5px; overflow:hidden; display:inline-block; width:250px; text-align:left;">
                                <div style="background:#1a3a5c; color:white; padding:7px 12px; font-size:17px; font-weight:bold; text-align:center; letter-spacing:1.5px;">
                                    <t t-esc="doc_label"/>
                                </div>
                                <div style="padding:8px 13px; font-size:12px; line-height:1.85;">
                                    <div><strong>Referencia Interna:</strong> <t t-esc="o.name"/></div>
                                    <div><strong>Fecha de Emisión:</strong> <span t-field="o.invoice_date"/></div>
                                    <!-- Datos del timbre: solo en factura timbrada -->
                                    <t t-if="o.cfdi_uuid">
                                        <div style="margin-top:4px;"><strong>Folio Fiscal:</strong><br/><span style="font-family:monospace; font-size:9.5px; white-space:nowrap;"><t t-esc="o.cfdi_uuid"/></span></div>
                                        <div style="margin-top:3px; font-size:10px;"><strong>Fecha de Certificación:</strong> <t t-esc="o._get_fecha_certificacion()"/></div>
                                        <div style="font-size:10px;"><strong>Serie Cert. SAT:</strong> <span style="font-family:monospace;"><t t-esc="o._get_certificado_sat()"/></span></div>
                                        <div style="font-size:10px;"><strong>Serie Cert. Contribuyente:</strong> <span style="font-family:monospace;"><t t-esc="o._get_certificado_contribuyente()"/></span></div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div style="border-bottom:2px solid #1a3a5c; margin-bottom:8px;"></div>

                    <!-- RECEPTOR -->
                    <div style="border:1px solid #c8d8e8; border-radius:3px; padding:6px 10px; margin-bottom:8px; background:#f7fafd;">
                        <table style="width:100%;">
                            <tr>
                                <td style="width:50%; font-size:11px; line-height:1.6;">
                                    <div style="font-weight:bold; color:#1a3a5c; font-size:12px;">RECEPTOR</div>
                                    <div style="font-weight:bold;"><t t-esc="o.partner_id.name"/></div>
                                    <div t-if="o.partner_id.street"><t t-esc="o.partner_id.street"/></div>
                                    <div><t t-esc="o.partner_id.city or ''"/><t t-if="o.partner_id.state_id">, <t t-esc="o.partner_id.state_id.name"/></t> <t t-esc="o.partner_id.zip or ''"/></div>
                                </td>
                                <td style="width:50%; font-size:11px; line-height:1.6; vertical-align:top;">
                                    <div><strong>RFC:</strong> <t t-esc="o.partner_id.vat or 'XAXX010101000'"/></div>
                                    <div><strong>Regimen Fiscal:</strong> <span t-field="o.partner_id.l10n_mx_edi_fiscal_regime"/></div>
                                    <div t-if="o.partner_id.phone or o.partner_id.mobile"><strong>Tel:</strong> <t t-esc="o.partner_id.phone or o.partner_id.mobile"/></div>
                                    <div t-if="o.partner_id.email"><strong>Email:</strong> <t t-esc="o.partner_id.email"/></div>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <!-- TABLA CONCEPTOS -->
                    <table style="width:100%; border-collapse:collapse; font-size:11px; margin-bottom:8px;">
                        <thead>
                            <tr style="background:#1a3a5c; color:white;">
                                <th style="padding:5px 6px; text-align:left; width:8%;">Clave SAT</th>
                                <th style="padding:5px 6px; text-align:left; width:36%;">Descripcion</th>
                                <th style="padding:5px 6px; text-align:center; width:7%;">Cant.</th>
                                <th style="padding:5px 6px; text-align:left; width:7%;">U.M.</th>
                                <th style="padding:5px 6px; text-align:right; width:13%;">Precio Unit.</th>
                                <th style="padding:5px 6px; text-align:center; width:8%;">Desc.</th>
                                <th style="padding:5px 6px; text-align:right; width:12%;">Importe</th>
                                <th style="padding:5px 6px; text-align:right; width:9%;">IVA</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.invoice_line_ids" t-as="line">
                                <tr t-if="line.display_type == 'product'" style="border-bottom:1px solid #e0e8f0;">
                                    <td style="padding:4px 6px; color:#555;"><t t-esc="line.product_id.l10n_mx_edi_code_sat or '01010101'"/></td>
                                    <td style="padding:4px 6px;"><t t-esc="line.name"/></td>
                                    <td style="padding:4px 6px; text-align:center;"><span t-field="line.quantity"/></td>
                                    <td style="padding:4px 6px;"><t t-esc="line.product_uom_id.name or 'Serv.'"/></td>
                                    <td style="padding:4px 6px; text-align:right;"><span t-field="line.price_unit" t-options='{"widget":"monetary","display_currency":o.currency_id}'/></td>
                                    <td style="padding:4px 6px; text-align:center;">
                                        <t t-if="line.discount"><t t-esc="str(int(round(line.discount))) + '%'"/></t>
                                        <t t-else="">-</t>
                                    </td>
                                    <td style="padding:4px 6px; text-align:right;"><span t-field="line.price_subtotal" t-options='{"widget":"monetary","display_currency":o.currency_id}'/></td>
                                    <td style="padding:4px 6px; text-align:right; color:#1a3a5c;">
                                        <t t-if="line.tax_ids"><t t-esc="str(int(round(line.tax_ids[0].amount))) + '%'"/></t>
                                        <t t-else="">-</t>
                                    </td>
                                </tr>
                                <tr t-elif="line.display_type == 'line_section'">
                                    <td colspan="8" style="padding:5px 6px; font-weight:bold; background:#eaf2fb; color:#1a3a5c;"><t t-esc="line.name"/></td>
                                </tr>
                                <tr t-elif="line.display_type == 'line_note'">
                                    <td colspan="8" style="padding:3px 6px; font-style:italic; color:#777; font-size:10px;"><t t-esc="line.name"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- NOTAS (banda de ancho completo, debajo de conceptos y arriba de totales) -->
                    <t t-set="_sub_notes" t-value="(o.subscription_id.invoice_notes if o.subscription_id else False) or (o.subscription_ids.filtered(lambda s: s.invoice_notes)[:1].invoice_notes if o.subscription_ids else False)"/>
                    <t t-if="_sub_notes">
                        <div style="border:1px solid #e0e0e0; padding:6px 10px; border-radius:3px; margin-bottom:8px; font-size:11px; color:#555;">
                            <strong>Notas:</strong> <span style="white-space:pre-wrap;"><t t-esc="_sub_notes"/></span>
                        </div>
                    </t>

                    <!-- TOTALES -->
                    <table style="width:100%; margin-bottom:8px;">
                        <tr>
                            <td style="width:55%; vertical-align:top; font-size:11px; color:#555;">
                                <div style="font-size:11px; color:#333;">
                                    <strong>Importe con letra:</strong> <t t-esc="o.currency_id.amount_to_text(o.amount_total)"/> <t t-esc="'%02d/100 M.N.' % int(round((o.amount_total % 1) * 100))"/>
                                    <br/><strong>Moneda:</strong> <t t-esc="o.currency_id.name"/> Pesos Mexicanos
                                </div>
                            </td>
                            <td style="width:45%; vertical-align:top;">
                                <table style="width:100%; border-collapse:collapse; font-size:12px;">
                                    <tr style="border-bottom:1px solid #e0e8f0;">
                                        <td style="padding:4px 10px; color:#555;">Subtotal</td>
                                        <td style="padding:4px 10px; text-align:right;"><span t-field="o.amount_untaxed" t-options='{"widget":"monetary","display_currency":o.currency_id}'/></td>
                                    </tr>
                                    <t t-if="o.amount_tax">
                                        <tr style="border-bottom:1px solid #e0e8f0;">
                                            <td style="padding:4px 10px; color:#555;">IVA <t t-esc="iva_rate"/>%</td>
                                            <td style="padding:4px 10px; text-align:right;"><span t-field="o.amount_tax" t-options='{"widget":"monetary","display_currency":o.currency_id}'/></td>
                                        </tr>
                                    </t>
                                    <tr style="background:#1a3a5c; color:white;">
                                        <td style="padding:6px 10px; font-weight:bold; font-size:13px;">TOTAL</td>
                                        <td style="padding:6px 10px; text-align:right; font-weight:bold; font-size:13px;"><span t-field="o.amount_total" t-options='{"widget":"monetary","display_currency":o.currency_id}'/></td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- CONDICIONES DE LA VENTA -->
                    <div style="border:1px solid #1a3a5c; border-radius:3px; margin-bottom:8px; overflow:hidden;">
                        <div style="background:#1a3a5c; color:white; padding:4px 10px; font-size:11px; font-weight:bold;">CONDICIONES DE LA VENTA</div>
                        <div style="padding:6px 10px; font-size:11px; line-height:1.7; background:#f7fafd;">
                            <table style="width:100%;">
                                <t t-set="_mp" t-value="o.partner_id.invoice_payment_method or 'PUE'"/>
                                <t t-set="_mp_desc" t-value="{'PUE': 'Pago en una sola exhibición', 'PPD': 'Pago en parcialidades o diferido'}.get(_mp, '')"/>
                                <tr>
                                    <t t-set="_cond_raw" t-value="o.partner_id.invoice_payment_condition or 'contado'"/>
                                    <t t-set="_cond" t-value="(o.partner_id.invoice_payment_condition_text or 'Otro') if _cond_raw == 'otro' else {'contado': 'Contado', 'credito': 'Crédito'}.get(_cond_raw, _cond_raw)"/>
                                    <td style="width:34%; vertical-align:top;"><strong>Condiciones de Pago:</strong> <t t-esc="_cond"/></td>
                                    <td style="width:33%; vertical-align:top;"><strong>Método de Pago:</strong> <t t-esc="_mp"/> - <t t-esc="_mp_desc"/></td>
                                    <td style="width:33%; vertical-align:top;"><strong>Forma de Pago:</strong> <span t-field="o.l10n_mx_edi_payment_method_id_code"/></td>
                                </tr>
                                <tr>
                                    <td style="vertical-align:top;"><strong>Lugar de Expedición:</strong> <t t-esc="o.company_id.zip or ''"/></td>
                                    <td style="vertical-align:top;"><strong>Uso de CFDI:</strong> <t t-if="o.partner_id.l10n_mx_edi_usage"><span t-field="o.partner_id.l10n_mx_edi_usage"/></t><t t-else="">G03 - Gastos en general</t></td>
                                    <td style="vertical-align:top;"><strong>Tipo de Comprobante:</strong> <t t-esc="'E - Egreso' if o.move_type == 'out_refund' else 'I - Ingreso'"/></td>
                                </tr>
                                <tr>
                                    <td style="vertical-align:top;"><strong>Exportación:</strong> 01 - No aplica</td>
                                    <td style="vertical-align:top;"></td>
                                    <td style="vertical-align:top;"></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- DATOS BANCARIOS (cuenta fiscal Banorte) -->
                    <t t-set="_bank" t-value="o._get_emisor_bank_info()"/>
                    <t t-if="_bank">
                        <div style="border:1px solid #1a3a5c; border-radius:3px; margin-bottom:8px; overflow:hidden;">
                            <div style="background:#1a3a5c; color:white; padding:4px 10px; font-size:11px; font-weight:bold;">DATOS PARA PAGO (DEPÓSITO O TRANSFERENCIA)</div>
                            <div style="padding:6px 10px; font-size:11px; line-height:1.7; background:#f7fafd;">
                                <table style="width:100%;">
                                    <tr>
                                        <td style="width:25%;"><strong>Banco:</strong> <t t-esc="_bank.get('banco')"/></td>
                                        <td style="width:25%;"><strong>Titular:</strong> <t t-esc="_bank.get('titular')"/></td>
                                        <td style="width:22%;"><strong>Cuenta:</strong> <t t-esc="_bank.get('cuenta')"/></td>
                                        <td style="width:28%;"><strong>CLABE:</strong> <t t-esc="_bank.get('clabe')"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </t>

                    <!-- SECCION CFDI -->
                    <t t-if="o.cfdi_uuid">
                        <t t-set="qr_b64" t-value="o._get_cfdi_qr_b64()"/>
                        <div style="border-top:2px solid #1a3a5c; margin-top:10px;">
                            <div style="background:#1a3a5c; color:white; padding:4px 10px; font-size:11px; font-weight:bold;">
                                TIMBRE FISCAL DIGITAL - CFDI 4.0
                            </div>
                            <div style="border:1px solid #c8d8e8; border-top:none; padding:8px 10px; background:#f7fafd;">
                                <div style="display:table; width:100%;">
                                    <!-- Datos fiscales (sin tablas/recuadros para verse limpio) -->
                                    <div style="display:table-cell; vertical-align:top; padding-right:12px; font-size:7px; line-height:1.5;">
                                        <div style="margin-bottom:5px;">
                                            <span style="color:#1a3a5c; font-weight:bold; font-size:9px;">Sello Digital del CFDI:</span><br/>
                                            <span style="font-family:monospace; word-break:break-all; overflow-wrap:break-word;"><t t-esc="o._get_sello_cfd()"/></span>
                                        </div>
                                        <div style="margin-bottom:5px;">
                                            <span style="color:#1a3a5c; font-weight:bold; font-size:9px;">Sello Digital del SAT:</span><br/>
                                            <span style="font-family:monospace; word-break:break-all; overflow-wrap:break-word;"><t t-esc="o._get_sello_sat()"/></span>
                                        </div>
                                        <div>
                                            <span style="color:#1a3a5c; font-weight:bold; font-size:9px;">Cadena Original del Complemento de Certificación:</span><br/>
                                            <span style="font-family:monospace; word-break:break-all; overflow-wrap:break-word;"><t t-esc="o._get_cadena_original_sat()"/></span>
                                        </div>
                                    </div>
                                    <!-- Codigo QR -->
                                    <div style="display:table-cell; vertical-align:top; text-align:center; width:130px;">
                                        <t t-if="qr_b64">
                                            <img t-att-src="'data:image/png;base64,' + qr_b64"
                                                 style="width:120px; height:120px; display:block; margin:0 auto;"/>
                                            <div style="font-size:7px; color:#555; margin-top:2px; text-align:center;">Verificar en sat.gob.mx</div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                            <div style="background:#1a3a5c; color:#aac4e0; font-size:9px; text-align:center; padding:3px 10px;">
                                Representacion impresa de un CFDI.
                                <span t-if="is_test" style="color:#f0c040; font-weight:bold;"> DOCUMENTO DE PRUEBA - Sin validez fiscal</span>
                            </div>
                        </div>
                    </t>

                    <!-- INVITACIÓN TELEGRAM — solo si el cliente NO está vinculado al Bot Clientes -->
                    <t t-if="'telegram_link_token' in o.partner_id._fields">
                        <t t-set="tg_qr" t-value="o.partner_id._telegram_qr_for_report()"/>
                        <t t-if="tg_qr">
                            <div style="border:1px solid #29a3df; border-radius:6px; margin-top:12px; background:#f2fbff; display:table; width:100%;">
                                <div style="display:table-cell; vertical-align:middle; padding:10px 14px;">
                                    <div style="color:#1a3a5c; font-weight:bold; font-size:12px; margin-bottom:3px;">
                                        🛡️ Únete a Sentinela en Telegram
                                    </div>
                                    <div style="font-size:9px; color:#333; line-height:1.5;">
                                        Recibe <b>avisos de tus alarmas</b>, el <b>rastreo en vivo</b> de tu técnico
                                        o patrulla, y recordatorios — directo en tu Telegram.<br/>
                                        Escanea el código con la cámara de tu celular para activarlo.
                                    </div>
                                </div>
                                <div style="display:table-cell; vertical-align:middle; text-align:center; width:96px; padding:6px;">
                                    <img t-att-src="'data:image/png;base64,' + tg_qr"
                                         style="width:84px; height:84px; display:block; margin:0 auto;"/>
                                </div>
                            </div>
                        </t>
                    </t>

                </div>
            </t>
        </xpath>
    </template>

</odoo>