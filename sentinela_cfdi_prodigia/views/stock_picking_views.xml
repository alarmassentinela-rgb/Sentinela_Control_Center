<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_credit_note" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.credit.note</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_generate_credit_note_from_return" 
                        string="Generar Nota de Crédito" 
                        type="object" 
                        class="oe_highlight"
                        invisible="state != 'done' or picking_type_code != 'incoming' or credit_note_id != False"/>
            </xpath>
            <xpath expr="//field[@name='origin']" position="after">
                <field name="credit_note_id" invisible="not credit_note_id"/>
            </xpath>
        </field>
    </record>
</odoo>
