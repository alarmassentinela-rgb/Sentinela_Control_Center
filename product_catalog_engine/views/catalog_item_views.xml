<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_catalog_item_list" model="ir.ui.view">
        <field name="name">distributor.catalog.item.list</field>
        <field name="model">distributor.catalog.item</field>
        <field name="arch" type="xml">
            <list>
                <field name="backend_id"/>
                <field name="distributor_product_id"/>
                <field name="name"/>
                <field name="brand"/>
                <field name="manufacturer_sku"/>
                <field name="sat_code"/>
                <field name="barcode"/>
                <field name="price_list"/>
                <field name="stock_total"/>
                <field name="product_tmpl_id"/>
                <field name="sync_tier"/>
            </list>
        </field>
    </record>

    <record id="view_catalog_item_search" model="ir.ui.view">
        <field name="name">distributor.catalog.item.search</field>
        <field name="model">distributor.catalog.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Buscar"
                       filter_domain="['|','|','|','|','|',('name','ilike',self),('code_norm','ilike',self),('manufacturer_sku','ilike',self),('sat_code','ilike',self),('barcode','ilike',self),('brand','ilike',self)]"/>
                <field name="backend_id"/>
                <field name="brand"/>
                <field name="sat_code"/>
                <filter name="promovidos" string="Promovidos" domain="[('product_tmpl_id','!=',False)]"/>
                <filter name="no_promovidos" string="Sin promover" domain="[('product_tmpl_id','=',False)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="g_backend" string="Distribuidor" context="{'group_by':'backend_id'}"/>
                    <filter name="g_brand" string="Marca" context="{'group_by':'brand'}"/>
                    <filter name="g_tier" string="Prioridad" context="{'group_by':'sync_tier'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_catalog_item_form" model="ir.ui.view">
        <field name="name">distributor.catalog.item.form</field>
        <field name="model">distributor.catalog.item</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_promote" type="object" string="Promover a Producto Maestro"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group string="Identidad">
                            <field name="backend_id"/>
                            <field name="distributor_product_id"/>
                            <field name="distributor_sku"/>
                            <field name="manufacturer_sku"/>
                            <field name="barcode"/>
                            <field name="sat_code"/>
                            <field name="code_norm"/>
                            <field name="product_tmpl_id"/>
                        </group>
                        <group string="Snapshot (indicativo)">
                            <field name="price_list"/>
                            <field name="price_cost"/>
                            <field name="currency_code"/>
                            <field name="stock_total"/>
                            <field name="snapshot_at"/>
                            <field name="thumb_url" widget="url"/>
                            <field name="image_count"/>
                            <field name="doc_count"/>
                            <field name="sync_tier"/>
                        </group>
                    </group>
                    <group>
                        <group string="Frescura">
                            <field name="freshness_status"/>
                            <field name="sync_source"/>
                            <field name="price_synced_at"/>
                            <field name="price_expires_at"/>
                            <field name="stock_synced_at"/>
                            <field name="stock_expires_at"/>
                            <field name="enrichment_synced_at"/>
                            <field name="enrichment_expires_at"/>
                        </group>
                        <group string="Prioridad">
                            <field name="is_favorite"/>
                            <field name="hit_count"/>
                            <field name="last_hit_at"/>
                        </group>
                    </group>
                    <group string="Búsqueda">
                        <field name="brand"/>
                        <field name="manufacturer"/>
                        <field name="category_path"/>
                        <field name="keywords"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_catalog_item" model="ir.actions.act_window">
        <field name="name">Índice de Catálogo</field>
        <field name="res_model">distributor.catalog.item</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_catalog_item_search"/>
    </record>

    <menuitem id="menu_catalog_index" name="Índice de Catálogo"
              parent="distributor_connector_base.menu_catalog_root"
              action="action_catalog_item" sequence="5"/>

    <!-- ===== Dashboard ===== -->
    <record id="view_catalog_dashboard_form" model="ir.ui.view">
        <field name="name">catalog.dashboard.form</field>
        <field name="model">catalog.dashboard</field>
        <field name="arch" type="xml">
            <form string="Estado del Motor de Catálogo">
                <header>
                    <button name="action_refresh" type="object" string="Actualizar" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Inventario del índice">
                            <field name="items_indexed"/>
                            <field name="items_promoted"/>
                            <field name="items_fresh"/>
                            <field name="items_expired"/>
                            <field name="items_never"/>
                            <field name="tier_summary"/>
                        </group>
                        <group string="Operación">
                            <field name="avg_sync_ms"/>
                            <field name="runs_error_24h"/>
                            <field name="events_24h"/>
                            <field name="cache_entries"/>
                        </group>
                    </group>
                    <group string="Por distribuidor">
                        <field name="by_distributor" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_catalog_dashboard" model="ir.actions.act_window">
        <field name="name">Estado del Motor</field>
        <field name="res_model">catalog.dashboard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <menuitem id="menu_catalog_dashboard" name="Estado del Motor"
              parent="distributor_connector_base.menu_catalog_root"
              action="action_catalog_dashboard" sequence="1"/>

    <!-- ===== Políticas de sincronización ===== -->
    <record id="view_catalog_sync_policy_list" model="ir.ui.view">
        <field name="name">catalog.sync.policy.list</field>
        <field name="model">catalog.sync.policy</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="data_type"/>
                <field name="backend_id"/>
                <field name="ttl_minutes"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="action_catalog_sync_policy" model="ir.actions.act_window">
        <field name="name">Políticas de Sincronización</field>
        <field name="res_model">catalog.sync.policy</field>
        <field name="view_mode">list</field>
    </record>
    <menuitem id="menu_catalog_sync_policy" name="Políticas de Sincronización"
              parent="distributor_connector_base.menu_catalog_root"
              action="action_catalog_sync_policy" sequence="30"/>
</odoo>
