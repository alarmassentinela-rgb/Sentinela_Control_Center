<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Server Action to notify salesperson -->
        <record id="action_server_fsm_notify_for_quote" model="ir.actions.server">
            <field name="name">FSM: Notify Salesperson for Quote</field>
            <field name="model_id" ref="model_sentinela_fsm_order"/>
            <field name="state">code</field>
            <field name="code">
if record:
    record.notify_salesperson_for_quote()
            </field>
        </record>

        <!-- Automated Action on Pause for Quote -->
        <record id="auto_action_fsm_quote_needed" model="base.automation">
            <field name="name">FSM: Notify Salesperson when a Quote is Needed</field>
            <field name="model_id" ref="model_sentinela_fsm_order"/>
            <field name="trigger">on_write</field>
            <field name="filter_pre_domain">[('stage', '!=', 'paused')]</field>
            <field name="filter_domain">[('stage', '=', 'paused'), ('pause_reason_id.is_quote_reason', '=', True)]</field>
            <field name="action_server_ids" eval="[(4, ref('action_server_fsm_notify_for_quote'))]"/>
        </record>

        <!-- Cron: generación automática de órdenes de mantenimiento preventivo -->
        <record id="action_generate_preventive_maintenance" model="ir.actions.server">
            <field name="name">FSM: Generar Mantenimiento Preventivo</field>
            <field name="model_id" ref="sentinela_subscriptions.model_sentinela_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_generate_preventive_maintenance()</field>
        </record>

        <record id="ir_cron_generate_preventive_maintenance" model="ir.cron">
            <field name="name">Sentinela FSM: Mantenimiento Preventivo Programado</field>
            <field name="ir_actions_server_id" ref="action_generate_preventive_maintenance"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
