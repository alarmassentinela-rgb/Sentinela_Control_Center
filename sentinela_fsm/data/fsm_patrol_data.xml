<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="task_patrol_doors" model="sentinela.fsm.task.template">
            <field name="name">Revisión de Puertas y Cerraduras</field>
            <field name="sequence">10</field>
            <field name="service_type">patrol</field>
        </record>
        <record id="task_patrol_windows" model="sentinela.fsm.task.template">
            <field name="name">Revisión de Ventanas y Cristales</field>
            <field name="sequence">20</field>
            <field name="service_type">patrol</field>
        </record>
        <record id="task_patrol_perimeter" model="sentinela.fsm.task.template">
            <field name="name">Inspección Perimetral (Bardas/Cercas)</field>
            <field name="sequence">30</field>
            <field name="service_type">patrol</field>
        </record>
        <record id="task_patrol_lighting" model="sentinela.fsm.task.template">
            <field name="name">Verificación de Iluminación Exterior</field>
            <field name="sequence">40</field>
            <field name="service_type">patrol</field>
        </record>
        <record id="task_patrol_suspicious" model="sentinela.fsm.task.template">
            <field name="name">Búsqueda de Vehículos/Personas Sospechosas</field>
            <field name="sequence">50</field>
            <field name="service_type">patrol</field>
        </record>

        <!-- F3.3 — Cron ETA en vivo del patrullero -->
        <record id="action_send_eta_updates" model="ir.actions.server">
            <field name="name">Send ETA Updates</field>
            <field name="model_id" ref="model_sentinela_fsm_order"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_eta_updates()</field>
        </record>

        <record id="ir_cron_send_eta_updates" model="ir.cron">
            <field name="name">Sentinela FSM: ETA en vivo del patrullero</field>
            <field name="ir_actions_server_id" ref="action_send_eta_updates"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">3</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
