<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sentinela_subscription_form_fsm" model="ir.ui.view">
        <field name="name">sentinela.subscription.form.fsm</field>
        <field name="model">sentinela.subscription</field>
        <field name="inherit_id" ref="sentinela_subscriptions.view_sentinela_subscription_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_fsm_orders" type="object" class="oe_stat_button" icon="fa-wrench">
                    <field name="fsm_order_count" widget="statinfo" string="Tickets"/>
                </button>
            </div>
            <xpath expr="//notebook" position="inside">
                <page string="Historial Técnico (FSM)" name="fsm_history">
                    <field name="fsm_order_ids" readonly="1">
                        <list>
                            <field name="name"/>
                            <field name="technician_id"/>
                            <field name="scheduled_date"/>
                            <field name="service_type"/>
                            <field name="stage" widget="badge"/>
                        </list>
                    </field>
                </page>
                <page string="🖼️ Expediente de Evidencias" name="fsm_evidence">
                    <field name="all_fsm_evidence_ids" readonly="1">
                        <kanban>
                            <field name="id"/>
                            <field name="name"/>
                            <field name="evidence_type"/>
                            <field name="image"/>
                            <templates>
                                <t t-name="card">
                                    <div class="oe_kanban_global_click" style="width: 200px; height: 200px; padding: 5px;">
                                        <div class="o_kanban_image" style="width: 100%; height: 140px;">
                                            <img t-att-src="kanban_image('sentinela.fsm.evidence', 'image', record.id.value)" 
                                                 style="width: 100%; height: 100%; object-fit: cover;" alt="Evidencia"/>
                                        </div>
                                        <div class="o_kanban_details" style="text-align: center; margin-top: 5px;">
                                            <strong class="o_kanban_record_title"><field name="name"/></strong>
                                            <div class="text-muted small">
                                                <field name="evidence_type" widget="badge"/>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
