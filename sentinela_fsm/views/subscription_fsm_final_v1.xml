<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sentinela_subscription_form_fsm" model="ir.ui.view">
        <field name="name">sentinela.subscription.form.fsm</field>
        <field name="model">sentinela.subscription</field>
        <field name="inherit_id" ref="sentinela_subscriptions.view_sentinela_subscription_form"/>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//button[@name='action_reactivate']" position="after">
                    <button name="action_reactivate_with_visit" string="Reconectar + Visita Técnica"
                        type="object" class="btn-info" icon="fa-wrench"
                        invisible="state != 'suspension'"/>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_fsm_orders" type="object" class="oe_stat_button" icon="fa-wrench">
                        <field name="fsm_order_count" widget="statinfo" string="Tickets"/>
                    </button>
                </xpath>
                <xpath expr="//notebook" position="inside">
                    <page string="🔧 Historial Técnico (FSM)" name="fsm_history">
                        <group string="Mantenimiento Preventivo (Póliza)">
                            <field name="maintenance_frequency"/>
                            <field name="next_maintenance_date" invisible="maintenance_frequency == '0'"/>
                            <field name="last_maintenance_date"/>
                        </group>
                        <field name="fsm_order_ids" readonly="1"/>
                    </page>
                </xpath>
            </data>
        </field>
    </record>
</odoo>
