<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- KANBAN VIEW -->
    <record id="view_fsm_order_kanban" model="ir.ui.view">
        <field name="name">sentinela.fsm.order.kanban</field>
        <field name="model">sentinela.fsm.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage" class="o_kanban_small_column" sample="1">
                <field name="stage"/>
                <field name="priority"/>
                <field name="technician_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <span class="float-end text-right">
                                        <field name="priority" widget="priority"/>
                                    </span>
                                </div>
                                <div class="text-muted">
                                    <field name="partner_id"/>
                                </div>
                                <div>
                                    <span class="fa fa-clock" title="Scheduled Date"/> <field name="scheduled_date"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="technician_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- CALENDAR VIEW -->
    <record id="view_fsm_order_calendar" model="ir.ui.view">
        <field name="name">sentinela.fsm.order.calendar</field>
        <field name="model">sentinela.fsm.order</field>
        <field name="arch" type="xml">
            <calendar string="Agenda del Equipo" date_start="scheduled_date" color="stage"
                      mode="month" event_open_popup="1" quick_create="0">
                <field name="technician_id" filters="1" avatar_field="image_128"/>
                <field name="service_type" filters="1"/>
                <field name="stage"/>
                <field name="partner_id"/>
                <field name="priority"/>
            </calendar>
        </field>
    </record>

    <!-- PIVOT — análisis de desempeño sobre órdenes reales (campos almacenados) -->
    <record id="view_fsm_order_pivot" model="ir.ui.view">
        <field name="name">sentinela.fsm.order.pivot</field>
        <field name="model">sentinela.fsm.order</field>
        <field name="arch" type="xml">
            <pivot string="Análisis de Órdenes" sample="1">
                <field name="technician_id" type="row"/>
                <field name="stage" type="col"/>
                <field name="actual_duration" type="measure"/>
                <field name="travel_time" type="measure"/>
                <field name="customer_rating" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- GRAPH — órdenes por técnico/estado -->
    <record id="view_fsm_order_graph" model="ir.ui.view">
        <field name="name">sentinela.fsm.order.graph</field>
        <field name="model">sentinela.fsm.order</field>
        <field name="arch" type="xml">
            <graph string="Órdenes por Técnico" type="bar" sample="1">
                <field name="technician_id"/>
                <field name="stage"/>
            </graph>
        </field>
    </record>

    <!-- LIST VIEW — colores por estado para leer pendientes de un vistazo -->
    <record id="view_fsm_order_list" model="ir.ui.view">
        <field name="name">sentinela.fsm.order.list</field>
        <field name="model">sentinela.fsm.order</field>
        <field name="arch" type="xml">
            <list string="Órdenes de Servicio" multi_edit="1"
                  decoration-success="stage == 'in_progress'"
                  decoration-info="stage == 'assigned'"
                  decoration-warning="stage in ('new','paused')"
                  decoration-muted="stage in ('done','cancel')">
                <field name="name"/>
                <field name="scheduled_date"/>
                <field name="partner_id"/>
                <field name="service_type"/>
                <field name="technician_id" widget="many2one_avatar_user"/>
                <field name="priority" widget="priority"/>
                <field name="stage" widget="badge"
                       decoration-success="stage == 'in_progress'"
                       decoration-info="stage == 'assigned'"
                       decoration-warning="stage in ('new','paused')"
                       decoration-muted="stage in ('done','cancel')"/>
            </list>
        </field>
    </record>

    <!-- SEARCH VIEW — filtros por técnico/patrullero, estado, tipo, agrupar -->
    <record id="view_fsm_order_search" model="ir.ui.view">
        <field name="name">sentinela.fsm.order.search</field>
        <field name="model">sentinela.fsm.order</field>
        <field name="arch" type="xml">
            <search string="Órdenes de Servicio">
                <field name="name" string="Folio / Descripción" filter_domain="['|', ('name','ilike',self), ('description','ilike',self)]"/>
                <field name="partner_id"/>
                <field name="technician_id" string="Técnico / Patrullero"/>
                <separator/>
                <filter name="f_pendientes" string="Pendientes"
                        domain="[('stage','in',('new','assigned','in_progress','paused'))]"/>
                <filter name="f_sin_asignar" string="Sin asignar"
                        domain="[('stage','=','new')]"/>
                <filter name="f_vivos" string="En proceso (vivos)"
                        domain="[('stage','=','in_progress')]"/>
                <filter name="f_pausados" string="Pausados"
                        domain="[('stage','=','paused')]"/>
                <filter name="f_terminados" string="Finalizados"
                        domain="[('stage','=','done')]"/>
                <separator/>
                <filter name="f_hoy" string="Programadas hoy"
                        domain="[('scheduled_date','&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))),
                                 ('scheduled_date','&lt;=', datetime.datetime.combine(context_today(), datetime.time(23,59,59)))]"/>
                <filter name="f_semana" string="Esta semana"
                        domain="[('scheduled_date','&gt;=', (context_today() + relativedelta(weeks=-1, days=1, weekday=0)).strftime('%Y-%m-%d')),
                                 ('scheduled_date','&lt;', (context_today() + relativedelta(weekday=6)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="f_patrullaje" string="Patrullaje" domain="[('service_type','=','patrol')]"/>
                <filter name="f_correctivo" string="Reparación / Falla" domain="[('service_type','=','repair')]"/>
                <filter name="f_preventivo" string="Mantenimiento" domain="[('service_type','=','maintenance')]"/>
                <separator/>
                <filter name="f_mias" string="Mis órdenes" domain="[('technician_id','=',uid)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="g_tec" string="Técnico / Patrullero" context="{'group_by':'technician_id'}"/>
                    <filter name="g_stage" string="Estado" context="{'group_by':'stage'}"/>
                    <filter name="g_type" string="Tipo de servicio" context="{'group_by':'service_type'}"/>
                    <filter name="g_dia" string="Día programado" context="{'group_by':'scheduled_date:day'}"/>
                    <filter name="g_prio" string="Prioridad" context="{'group_by':'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_fsm_order_form" model="ir.ui.view">
        <field name="name">sentinela.fsm.order.form</field>
        <field name="model">sentinela.fsm.order</field>
        <field name="arch" type="xml">
            <form string="Orden de Servicio">
                <header>
                    <button name="action_open_map" string="Navegar (Maps)" type="object" class="btn-secondary" icon="fa-map-marker"/>
                    <button name="action_assign" string="Programar / Asignar" type="object" class="btn-primary" invisible="stage != 'new'"/>
                    <button name="action_start" string="Iniciar Trabajo" type="object" class="oe_highlight" invisible="stage != 'assigned'"/>
                    <button name="%(action_fsm_order_pause_wizard)d" string="Pausar" type="action" class="btn-warning" invisible="stage != 'in_progress'"/>
                    <button name="action_resume" string="Reanudar" type="object" class="oe_highlight" invisible="stage != 'paused'"/>
                    <button name="action_finish" string="Finalizar" type="object" class="btn-success" invisible="stage != 'in_progress'"/>
                    <field name="stage" widget="statusbar" options="{'clickable': '1'}" statusbar_visible="new,assigned,in_progress,paused,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group invisible="stage != 'paused'" class="alert alert-warning" role="alert">
                        <field name="pause_reason_id" options="{'no_open': True}"/>
                        <field name="pause_notes"/>
                    </group>
                    <field name="is_fsm_manager" invisible="1"/>
                    <group>
                        <group string="Cliente">
                            <field name="partner_id" readonly="not is_fsm_manager and stage != 'new'"/>
                            <field name="phone"/>
                            <field name="service_address_id" context="{'default_parent_id': partner_id}" readonly="not is_fsm_manager and stage != 'new'"/>
                            <field name="subscription_id" readonly="not is_fsm_manager and stage != 'new'"/>
                            <field name="description" placeholder="Detalle del reporte..."/>
                        </group>
                        <group string="Programación">
                            <field name="service_type" readonly="not is_fsm_manager and stage != 'new'"/>
                            <field name="technician_id" readonly="not is_fsm_manager"
                                   invisible="service_type == 'patrol'"/>
                            <field name="patrol_agent_id" readonly="not is_fsm_manager"
                                   invisible="service_type != 'patrol'"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="patrol_unit_id" readonly="not is_fsm_manager"
                                   invisible="service_type != 'patrol'"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="scheduled_date" readonly="not is_fsm_manager"/>
                            <field name="priority" widget="priority" readonly="not is_fsm_manager and stage != 'new'"/>
                            <field name="duration_expected" readonly="not is_fsm_manager"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Evidencias (Fotos)" name="evidence">
                            <field name="evidence_ids" mode="kanban">
                                <kanban>
                                    <field name="id"/>
                                    <field name="image"/>
                                    <field name="name"/>
                                    <field name="evidence_type"/>
                                    <templates>
                                        <t t-name="card">
                                            <div class="row g-0">
                                                <div class="col-4">
                                                    <field name="image" widget="image" class="img-thumbnail" style="max-height: 80px;"/>
                                                </div>
                                                <div class="col-8 ps-2">
                                                    <strong class="d-block"><field name="evidence_type"/></strong>
                                                    <span class="text-muted"><field name="name"/></span>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                                <form>
                                    <group>
                                        <field name="evidence_type"/>
                                        <field name="name"/>
                                        <field name="image" widget="image"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Checklist" name="checklist">
                            <field name="checklist_ids">
                                <list editable="bottom">
                                    <field name="is_done"/>
                                    <field name="name"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Instalación / Unidad" name="vehicle_info" invisible="service_type not in ['install', 'repair', 'maintenance', 'transfer']">
                            <group string="📍 Ubicación Real de la Instalación">
                                <group>
                                    <field name="install_lat"/>
                                    <field name="install_lon"/>
                                </group>
                                <group>
                                    <p class="text-muted">Captura las coordenadas donde se instaló físicamente el equipo para referencia futura en Google Maps.</p>
                                </group>
                            </group>
                            <group>
                                                                 <!-- Campos para GPS -->
                                                                <group string="Datos del Vehículo (Senticar)" invisible="subscription_id and service_type != 'gps'">                                    <field name="vehicle_brand" placeholder="Ej. Nissan"/>
                                    <field name="vehicle_model" placeholder="Ej. NP300"/>
                                    <field name="vehicle_color" placeholder="Ej. Blanco"/>
                                    <field name="vehicle_plate" placeholder="Ej. ABC-1234"/>
                                    <field name="sim_iccid" placeholder="ICCID de la SIM instalada"/>
                                </group>
                                <!-- Campos para Alarma -->
                                <group string="Datos del Panel (Alarma)" invisible="service_type != 'install' and not alarm_panel_brand and not monitoring_account_number">
                                    <field name="alarm_panel_brand" placeholder="Ej. Honeywell / DSC"/>
                                    <field name="alarm_panel_model" placeholder="Ej. Vista 48"/>
                                    <field name="monitoring_account_number" placeholder="Ej. 1234"/>
                                    <field name="alarm_zones" placeholder="Zona 1: Puerta..."/>
                                </group>
                                <!-- Campos para Internet -->
                                <group string="Datos de Conexión (Internet)" invisible="service_type != 'install' and not internet_antenna_mac">
                                    <field name="internet_antenna_mac" placeholder="Ej. AA:BB:CC..."/>
                                    <field name="internet_router_serial"/>
                                    <field name="internet_signal_dbm" placeholder="Ej. -65 dBm"/>
                                    <field name="internet_pppoe_user"/>
                                </group>
                            </group>
                        </page>
                        <page string="Resolución" invisible="stage in ['new', 'assigned']">
                            <group>
                                <group>
                                    <field name="check_in_date" readonly="1"/>
                                    <field name="check_out_date" readonly="1"/>
                                    <field name="actual_start_time"/>
                                    <field name="actual_end_time"/>
                                    <field name="planned_duration"/>
                                    <field name="actual_duration" readonly="1"/>
                                    <field name="travel_time"/>
                                    <field name="work_time" readonly="1"/>
                                    <field name="equipment_cost" readonly="1"/>
                                </group>
                            </group>
                            <field name="resolution_notes" placeholder="Describa el trabajo realizado..."/>
                            <group>
                                <field name="customer_signature" widget="signature"/>
                                <field name="customer_rating" widget="int_rate" options="{'size': 5}"/>
                                <field name="customer_feedback" placeholder="Comentarios del cliente..."/>
                            </group>
                        </page>
                        <page string="Equipos y Materiales" name="equipment">
                            <field name="equipment_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="total_price" readonly="1"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Localización" name="location">
                            <group>
                                <group string="Ubicación Check-In">
                                    <field name="check_in_lat"/>
                                    <field name="check_in_lon"/>
                                </group>
                                <group string="Ubicación Check-Out">
                                    <field name="check_out_lat"/>
                                    <field name="check_out_lon"/>
                                </group>
                                <group string="Distancia">
                                    <field name="distance_traveled"/>
                                </group>
                            </group>
                        </page>
                        <page string="Comunicación" name="communication">
                            <header>
                                <button name="%(action_fsm_chat_send_message_wizard)d" string="Enviar Mensaje" type="action" class="btn-primary"/>
                            </header>
                            <group>
                                <field name="chat_message_ids" nolabel="1" colspan="2"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_fsm_order" model="ir.actions.act_window">
        <field name="name">Órdenes de Servicio</field>
        <field name="res_model">sentinela.fsm.order</field>
        <field name="view_mode">list,kanban,calendar,form</field>
        <field name="search_view_id" ref="view_fsm_order_search"/>
        <field name="context">{'search_default_f_pendientes': 1}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Crear la primera Orden de Servicio
          </p>
        </field>
    </record>

    <!-- ANÁLISIS DE DESEMPEÑO — pivot/gráfica/lista sobre órdenes reales -->
    <record id="action_fsm_order_analysis" model="ir.actions.act_window">
        <field name="name">Análisis de Desempeño</field>
        <field name="res_model">sentinela.fsm.order</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="view_fsm_order_search"/>
        <field name="context">{'search_default_g_tec': 1}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Aún no hay órdenes para analizar.
          </p>
        </field>
    </record>

