<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fsm_schedule_wizard_form" model="ir.ui.view">
        <field name="name">sentinela.fsm.schedule.wizard.form</field>
        <field name="model">sentinela.fsm.schedule.wizard</field>
        <field name="arch" type="xml">
            <form string="Programar orden">
                <group>
                    <field name="order_id" invisible="1"/>
                    <field name="scheduled_date"/>
                    <field name="technician_id"
                           help="Si eliges técnico, la orden pasa a 'Asignado' y se le notifica."/>
                </group>
                <footer>
                    <button name="action_schedule" type="object" string="Programar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
