<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fsm_generate_order_wizard_form" model="ir.ui.view">
        <field name="name">sentinela.fsm.generate.order.wizard.form</field>
        <field name="model">sentinela.fsm.generate.order.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar Orden de Servicio">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="service_address_id"/>
                            <field name="subscription_id"/>
                            <field name="sale_order_id" invisible="not sale_order_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="service_type"/>
                            <field name="priority"/>
                            <field name="technician_id"/>
                            <field name="scheduled_date"/>
                        </group>
                    </group>
                    <group string="Descripción del Trabajo">
                        <field name="description" nolabel="1"
                            placeholder="Describe el trabajo a realizar para el técnico..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_create_order" string="Crear Orden" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
