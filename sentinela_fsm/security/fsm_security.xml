<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_fsm" model="ir.module.category">
            <field name="name">Gestión de Servicios</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_fsm_user" model="res.groups">
            <field name="name">Técnico</field>
            <field name="category_id" ref="module_category_fsm"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_fsm_dispatcher" model="res.groups">
            <field name="name">Recepción / Despacho</field>
            <field name="category_id" ref="module_category_fsm"/>
            <field name="implied_ids" eval="[(4, ref('group_fsm_user'))]"/>
        </record>

        <record id="group_fsm_manager" model="res.groups">
            <field name="name">Coordinador / Manager</field>
            <field name="category_id" ref="module_category_fsm"/>
            <field name="implied_ids" eval="[(4, ref('group_fsm_user')), (4, ref('group_fsm_dispatcher'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>

    <!-- Reglas de registro: noupdate=0 para que un upgrade las actualice -->
    <data noupdate="0">
        <!-- Cualquier usuario de Gestión de Servicios VE TODAS las órdenes (lectura global).
             El tablero/calendario muestra el trabajo de todo el equipo. -->
        <record id="fsm_order_user_read_all_rule" model="ir.rule">
            <field name="name">FSM Order — Técnico ve todas (lectura)</field>
            <field name="model_id" ref="model_sentinela_fsm_order"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fsm_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Pero un Técnico solo EDITA/crea/borra las órdenes donde él es el técnico. -->
        <record id="fsm_order_user_rule" model="ir.rule">
            <field name="name">FSM Order — Técnico edita solo las suyas</field>
            <field name="model_id" ref="model_sentinela_fsm_order"/>
            <field name="domain_force">[('technician_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_fsm_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Recepción/Despacho y Manager: ven y gestionan TODAS. -->
        <record id="fsm_order_dispatcher_rule" model="ir.rule">
            <field name="name">FSM Order — Recepción/Despacho gestiona todas</field>
            <field name="model_id" ref="model_sentinela_fsm_order"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fsm_dispatcher'))]"/>
        </record>

        <record id="fsm_order_manager_rule" model="ir.rule">
            <field name="name">FSM Order — Manager gestiona todas</field>
            <field name="model_id" ref="model_sentinela_fsm_order"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fsm_manager'))]"/>
        </record>
    </data>
</odoo>
