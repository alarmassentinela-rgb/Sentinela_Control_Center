<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_syscom" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.syscom</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app_settings string="Syscom Integration" title="Manage Syscom API connection">
                    <block title="API Credentials">
                        <setting>
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="syscom_client_id" class="col-lg-3 o_light_label"/>
                                    <field name="syscom_client_id"/>
                                </div>
                                <div class="row mt16">
                                    <label for="syscom_client_secret" class="col-lg-3 o_light_label"/>
                                    <field name="syscom_client_secret" password="True"/>
                                </div>
                                <div class="mt16">
                                    <button name="action_test_syscom_connection" type="object" string="Test Connection" class="btn-primary"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Sincronización de Catálogo (Cron Nocturno)" help="El cron diario, además de actualizar precio/stock, trae los SKUs NUEVOS de las marcas/categorías de abajo y depura los descontinuados.">
                        <setting id="syscom_cron_control" help="Enciende/apaga el cron y define cuándo corre. Hora = inicio; Cada = frecuencia (1 día = 1 vez al día). Los cambios se aplican al Guardar.">
                            <field name="syscom_cron_active" widget="boolean_toggle"/>
                            <div class="content-group mt8" invisible="not syscom_cron_active">
                                <span>Hora: </span><field name="syscom_cron_hour" widget="float_time" class="oe_inline"/>
                                <span class="ms-3">Cada </span><field name="syscom_cron_interval_number" class="oe_inline"/>
                                <field name="syscom_cron_interval_type" class="oe_inline"/>
                            </div>
                            <div class="text-muted small mt4"><field name="syscom_cron_info" nolabel="1" readonly="1"/></div>
                        </setting>
                        <setting string="Marcas a sincronizar (nuevos)" help="SKUs nuevos de estas marcas se importan solos. UNA POR LÍNEA, nombre tal como aparece en Syscom.">
                            <field name="syscom_sync_brands" widget="text" placeholder="HiLook by HIKVISION&#10;HIKVISION&#10;UBIQUITI"/>
                        </setting>
                        <setting string="Categorías a sincronizar (nuevos)" help="Opcional. SKUs nuevos de estas categorías, UNA POR LÍNEA. ⚠️ Una categoría grande trae miles de productos.">
                            <field name="syscom_sync_categories" widget="text" placeholder="Videovigilancia&#10;Redes e IT"/>
                        </setting>
                        <setting string="Máx. peticiones/min a Syscom" help="Tope de ritmo a la API (límite real ~300/min). El cron se auto-regula bajo este número.">
                            <field name="syscom_max_rpm"/>
                        </setting>
                        <setting string="Depurar descontinuados automáticamente" help="Borra descontinuados SIN movimiento; archiva los que SÍ tienen (preserva historia).">
                            <field name="syscom_autodelete_discontinued"/>
                        </setting>
                    </block>
                    <block title="Reporte Telegram (Cron Nocturno)" help="Opcional. Si se configura, el cron diario envía un resumen al chat indicado.">
                        <setting>
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="syscom_telegram_token" class="col-lg-3 o_light_label"/>
                                    <field name="syscom_telegram_token" password="True"/>
                                </div>
                                <div class="row mt16">
                                    <label for="syscom_telegram_chat_id" class="col-lg-3 o_light_label"/>
                                    <field name="syscom_telegram_chat_id"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app_settings>
            </xpath>
        </field>
    </record>
</odoo>
