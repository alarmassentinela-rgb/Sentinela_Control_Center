<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_syscom" model="ir.ui.view">
        <field name="name">product.template.form.syscom</field>
        <field name="model" >product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='inventory']" position="after">
                <page string="Datos Syscom" name="syscom">
                    <div class="alert alert-danger" role="alert" invisible="not syscom_discontinued">
                        ⚠️ <strong>Producto DESCONTINUADO en Syscom</strong>
                        (detectado el <field name="syscom_discontinued_date" readonly="1" class="oe_inline"/>).
                        Puede depurarse desde el wizard "Limpiar Productos Descontinuados".
                    </div>
                    <group>
                        <group string="Información de Integración">
                            <field name="syscom_id" readonly="1"/>
                            <field name="syscom_model"/>
                            <field name="syscom_brand" readonly="1"/>
                            <field name="syscom_stock" decoration-bf="1" decoration-success="syscom_stock &gt; 0" decoration-danger="syscom_stock == 0"/>
                            <field name="syscom_discontinued" readonly="1"/>
                        </group>
                        <group string="Estado de Sincronización">
                            <field name="syscom_last_update" readonly="1"/>
                            <field name="syscom_link" widget="url"/>
                            <field name="syscom_weight"/>
                        </group>
                        <group string="Precios de Referencia (USD)">
                            <field name="syscom_list_price_usd" string="Precio de Lista USD"/>
                            <field name="syscom_suggested_price_usd" string="Precio Especial USD"/>
                            <field name="syscom_price_usd" string="Precio Distribuidor 1 USD"/>
                        </group>
                        <group string="Datos Fiscales (SAT)">
                            <field name="syscom_sat_description"/>
                            <field name="syscom_sat_unit_key"/>
                        </group>
                        <group string="Recursos">
                            <field name="syscom_datasheet_url" widget="url" string="Ficha Técnica (PDF)"/>
                        </group>
                    </group>
                    <group string="Características">
                        <field name="syscom_caracteristicas" nolabel="1"/>
                    </group>
                    <group string="Detalle Técnico">
                        <field name="syscom_description" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>