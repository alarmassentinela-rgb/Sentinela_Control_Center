<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_in_invoice_tree_inherit_syscom" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.syscom</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_in_invoice_bill_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button name="action_sync_syscom_invoices" 
                            string="🔄 Sincronizar desde Syscom" 
                            type="object" 
                            class="btn-secondary"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
